IDENTIFICATION DIVISION.
PROGRAM-ID. WSDATETEST.

ENVIRONMENT DIVISION.
DATA DIVISION.
WORKING-STORAGE SECTION.

COPY "ws-date-validate.cpy".

01 WS-TEST-NUM        PIC 9(3) VALUE ZERO.
01 WS-PASS-COUNT      PIC 9(3) VALUE ZERO.
01 WS-FAIL-COUNT      PIC 9(3) VALUE ZERO.
01 WS-EXPECTED-DATE   PIC 9(8).
01 WS-EXPECTED-RC     PIC 9.

PROCEDURE DIVISION.
MAIN-LOGIC.
    DISPLAY "=== ws-date-validate.cpy unit tests (22 cases) ===".

    DISPLAY " ".
    DISPLAY "--- SUBTRACT-1-DAY (12 cases) ---".

    MOVE 20260611 TO WS-DV-INPUT-DATE
    MOVE 20260610 TO WS-EXPECTED-DATE PERFORM TEST-SUBTRACT
    MOVE 20250301 TO WS-DV-INPUT-DATE
    MOVE 20250228 TO WS-EXPECTED-DATE PERFORM TEST-SUBTRACT
    MOVE 20240301 TO WS-DV-INPUT-DATE
    MOVE 20240229 TO WS-EXPECTED-DATE PERFORM TEST-SUBTRACT
    MOVE 21000301 TO WS-DV-INPUT-DATE
    MOVE 21000228 TO WS-EXPECTED-DATE PERFORM TEST-SUBTRACT
    MOVE 20000301 TO WS-DV-INPUT-DATE
    MOVE 20000229 TO WS-EXPECTED-DATE PERFORM TEST-SUBTRACT
    MOVE 20230301 TO WS-DV-INPUT-DATE
    MOVE 20230228 TO WS-EXPECTED-DATE PERFORM TEST-SUBTRACT
    MOVE 20260101 TO WS-DV-INPUT-DATE
    MOVE 20251231 TO WS-EXPECTED-DATE PERFORM TEST-SUBTRACT
    MOVE 20260401 TO WS-DV-INPUT-DATE
    MOVE 20260331 TO WS-EXPECTED-DATE PERFORM TEST-SUBTRACT
    MOVE 20260501 TO WS-DV-INPUT-DATE
    MOVE 20260430 TO WS-EXPECTED-DATE PERFORM TEST-SUBTRACT
    MOVE 99991231 TO WS-DV-INPUT-DATE
    MOVE 99991230 TO WS-EXPECTED-DATE PERFORM TEST-SUBTRACT
    MOVE 19000201 TO WS-DV-INPUT-DATE
    MOVE 19000131 TO WS-EXPECTED-DATE PERFORM TEST-SUBTRACT
    MOVE 20240229 TO WS-DV-INPUT-DATE
    MOVE 20240228 TO WS-EXPECTED-DATE PERFORM TEST-SUBTRACT

    DISPLAY " ".
    DISPLAY "--- IS-VALID-GREGORIAN-DATE (10 cases) ---".

    MOVE 20260611 TO WS-DV-INPUT-DATE
    MOVE 0 TO WS-EXPECTED-RC PERFORM TEST-VALIDATE
    MOVE 20260231 TO WS-DV-INPUT-DATE
    MOVE 2 TO WS-EXPECTED-RC PERFORM TEST-VALIDATE
    MOVE 20240230 TO WS-DV-INPUT-DATE
    MOVE 2 TO WS-EXPECTED-RC PERFORM TEST-VALIDATE
    MOVE 20251301 TO WS-DV-INPUT-DATE
    MOVE 1 TO WS-EXPECTED-RC PERFORM TEST-VALIDATE
    MOVE 19000229 TO WS-DV-INPUT-DATE
    MOVE 2 TO WS-EXPECTED-RC PERFORM TEST-VALIDATE
    MOVE 20240229 TO WS-DV-INPUT-DATE
    MOVE 0 TO WS-EXPECTED-RC PERFORM TEST-VALIDATE
    MOVE 20000229 TO WS-DV-INPUT-DATE
    MOVE 0 TO WS-EXPECTED-RC PERFORM TEST-VALIDATE
    MOVE 20260000 TO WS-DV-INPUT-DATE
    MOVE 1 TO WS-EXPECTED-RC PERFORM TEST-VALIDATE
    MOVE 18991231 TO WS-DV-INPUT-DATE
    MOVE 3 TO WS-EXPECTED-RC PERFORM TEST-VALIDATE
    MOVE 20260631 TO WS-DV-INPUT-DATE
    MOVE 2 TO WS-EXPECTED-RC PERFORM TEST-VALIDATE

    DISPLAY " ".
    DISPLAY "=== Total: " WS-TEST-NUM
            " | PASS: " WS-PASS-COUNT
            " | FAIL: " WS-FAIL-COUNT.

    IF WS-FAIL-COUNT > 0 THEN
        MOVE 1 TO RETURN-CODE
    END-IF.
    STOP RUN.

TEST-SUBTRACT.
    ADD 1 TO WS-TEST-NUM.
    PERFORM SUBTRACT-1-DAY.
    IF WS-DV-OUTPUT-DATE = WS-EXPECTED-DATE THEN
        ADD 1 TO WS-PASS-COUNT
        DISPLAY "  [PASS] case " WS-TEST-NUM
                " sub(" WS-DV-INPUT-DATE ") = " WS-DV-OUTPUT-DATE
    ELSE
        ADD 1 TO WS-FAIL-COUNT
        DISPLAY "  [FAIL] case " WS-TEST-NUM
                " sub(" WS-DV-INPUT-DATE ") = " WS-DV-OUTPUT-DATE
                " (expected " WS-EXPECTED-DATE ")"
    END-IF.

TEST-VALIDATE.
    ADD 1 TO WS-TEST-NUM.
    PERFORM IS-VALID-GREGORIAN-DATE.
    IF WS-DV-RC = WS-EXPECTED-RC THEN
        ADD 1 TO WS-PASS-COUNT
        DISPLAY "  [PASS] case " WS-TEST-NUM
                " validate(" WS-DV-INPUT-DATE ") RC=" WS-DV-RC
    ELSE
        ADD 1 TO WS-FAIL-COUNT
        DISPLAY "  [FAIL] case " WS-TEST-NUM
                " validate(" WS-DV-INPUT-DATE ") RC=" WS-DV-RC
                " (expected " WS-EXPECTED-RC ")"
    END-IF.

COPY "ws-date-validate-procs.cpy".
