IDENTIFICATION DIVISION.
PROGRAM-ID. DEHTEST.

ENVIRONMENT DIVISION.
DATA DIVISION.
WORKING-STORAGE SECTION.

COPY "double-entry-helper.cpy".

01 WS-TEST-NUM        PIC 9(3) VALUE 0.
01 WS-PASS-COUNT      PIC 9(3) VALUE 0.
01 WS-FAIL-COUNT      PIC 9(3) VALUE 0.
01 WS-EXPECTED-RC     PIC 9(2).

PROCEDURE DIVISION.
MAIN-LOGIC.
    DISPLAY "=== DEH-VALIDATE unit tests (9 cases per DM §13.2) ===".

    MOVE 10 TO DEH-CAT
    MOVE +1000 TO DEH-AMOUNT-JPY
    MOVE "0010000000001" TO DEH-DR-ACCT
    MOVE "0010000000002" TO DEH-CR-ACCT
    MOVE 0 TO WS-EXPECTED-RC PERFORM ASSERT-RC

    MOVE 20 TO DEH-CAT
    MOVE -500 TO DEH-AMOUNT-JPY
    MOVE 0 TO WS-EXPECTED-RC PERFORM ASSERT-RC

    MOVE 30 TO DEH-CAT
    MOVE +2000 TO DEH-AMOUNT-JPY
    MOVE 0 TO WS-EXPECTED-RC PERFORM ASSERT-RC

    MOVE 40 TO DEH-CAT
    MOVE -10000 TO DEH-AMOUNT-JPY
    MOVE 0 TO WS-EXPECTED-RC PERFORM ASSERT-RC

    MOVE 50 TO DEH-CAT
    MOVE +25 TO DEH-AMOUNT-JPY
    MOVE 0 TO WS-EXPECTED-RC PERFORM ASSERT-RC

    MOVE 60 TO DEH-CAT
    MOVE -300 TO DEH-AMOUNT-JPY
    MOVE 0 TO WS-EXPECTED-RC PERFORM ASSERT-RC

    MOVE 99 TO DEH-CAT
    MOVE +1000 TO DEH-AMOUNT-JPY
    MOVE 30 TO WS-EXPECTED-RC PERFORM ASSERT-RC

    MOVE 10 TO DEH-CAT
    MOVE -1000 TO DEH-AMOUNT-JPY
    MOVE 20 TO WS-EXPECTED-RC PERFORM ASSERT-RC

    MOVE 10 TO DEH-CAT
    MOVE +1000 TO DEH-AMOUNT-JPY
    MOVE SPACES TO DEH-DR-ACCT
    MOVE 40 TO WS-EXPECTED-RC PERFORM ASSERT-RC

    DISPLAY " ".
    DISPLAY "=== Total: " WS-TEST-NUM
            " | PASS: " WS-PASS-COUNT
            " | FAIL: " WS-FAIL-COUNT.

    IF WS-FAIL-COUNT > 0 THEN
        MOVE 1 TO RETURN-CODE
    END-IF.
    STOP RUN.

ASSERT-RC.
    ADD 1 TO WS-TEST-NUM.
    PERFORM DEH-VALIDATE.
    IF DEH-RC = WS-EXPECTED-RC THEN
        ADD 1 TO WS-PASS-COUNT
        DISPLAY "  [PASS] " WS-TEST-NUM
                " cat=" DEH-CAT
                " amt=" DEH-AMOUNT-JPY
                " rc=" DEH-RC
                " msg=" FUNCTION TRIM(DEH-MSG)
    ELSE
        ADD 1 TO WS-FAIL-COUNT
        DISPLAY "  [FAIL] " WS-TEST-NUM
                " cat=" DEH-CAT
                " amt=" DEH-AMOUNT-JPY
                " rc=" DEH-RC " (expected " WS-EXPECTED-RC ")"
                " msg=" FUNCTION TRIM(DEH-MSG)
    END-IF.

COPY "double-entry-helper-procs.cpy".
