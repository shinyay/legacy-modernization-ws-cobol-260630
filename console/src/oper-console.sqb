               WHEN "ST_RUN"       MOVE WS-MVAL TO LBL-ST-RUN
               WHEN "ST_DONE"      MOVE WS-MVAL TO LBL-ST-DONE
               WHEN "ST_FAIL"      MOVE WS-MVAL TO LBL-ST-FAIL
               WHEN "S10"          MOVE WS-MVAL TO LBL-S10
