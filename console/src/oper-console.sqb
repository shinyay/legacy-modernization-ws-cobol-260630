               WHEN "P_BDATE"      MOVE WS-MVAL TO LBL-P-BDATE
               WHEN "P_CATQ"       MOVE WS-MVAL TO LBL-P-CATQ
               WHEN "P_ACCTQ"      MOVE WS-MVAL TO LBL-P-ACCTQ
               WHEN "P_PAYEEQ"     MOVE WS-MVAL TO LBL-P-PAYEEQ
