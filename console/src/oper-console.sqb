       EXEC SQL INCLUDE SQLCA END-EXEC.

       PROCEDURE DIVISION.
       MAIN-LOGIC.
           PERFORM PARSE-ARGS
           PERFORM INIT-THEME
           PERFORM SET-TODAY
           PERFORM REVS-INIT-ENV
           PERFORM LOAD-MESSAGES
           PERFORM DB-CONNECT
           IF NOT WS-CONNECTED
               DISPLAY "[ERROR] PG connection failed" UPON SYSERR
               MOVE 12 TO WS-RETURN-CODE
               GO TO PROGRAM-EXIT
           END-IF
           IF SCRIPTED-ON
               PERFORM DISPATCH-TRAN
           ELSE
               PERFORM MENU-LOOP
           END-IF
           GO TO PROGRAM-EXIT.

       PROGRAM-EXIT.
           IF SCREEN-ON
               PERFORM ANSI-RESET
           END-IF
           PERFORM DB-DISCONNECT
           STOP RUN RETURNING WS-RETURN-CODE.

       PARSE-ARGS.
           ACCEPT WS-ARG-CNT FROM ARGUMENT-NUMBER
           IF WS-ARG-CNT = 0
               EXIT PARAGRAPH
           END-IF
           PERFORM VARYING WS-ARG-IDX FROM 1 BY 1
                   UNTIL WS-ARG-IDX > WS-ARG-CNT
               DISPLAY WS-ARG-IDX UPON ARGUMENT-NUMBER
               ACCEPT WS-ARG-VALUE FROM ARGUMENT-VALUE
               EVALUATE TRUE
                   WHEN WS-ARG-VALUE(1:8) = "--screen"
                       SET SCREEN-ON TO TRUE
                   WHEN WS-ARG-VALUE(1:11) = "--no-screen"
                       MOVE "N" TO WS-SCREEN-MODE
                   WHEN WS-ARG-VALUE(1:7) = "--lang="
                       MOVE WS-ARG-VALUE(8:2) TO WS-LANG
                   WHEN WS-ARG-VALUE(1:7) = "--tran="
                       MOVE WS-ARG-VALUE(8:4) TO WS-TRAN-ARG
                       MOVE WS-ARG-VALUE(8:4) TO WS-TRAN-IN
                       MOVE "Y" TO WS-SCRIPTED
                   WHEN WS-ARG-VALUE(1:6) = "--key="
                       MOVE WS-ARG-VALUE(7:13) TO WS-KEY
                   WHEN WS-ARG-VALUE(1:7) = "--scen="
                       MOVE WS-ARG-VALUE(8:12) TO WS-SCEN-ARG
                   WHEN WS-ARG-VALUE(1:8) = "--theme="
                       MOVE WS-ARG-VALUE(9:8) TO WS-THEME
                   WHEN OTHER
                       CONTINUE
               END-EVALUATE
           END-PERFORM.

       SET-TODAY.
           MOVE FUNCTION CURRENT-DATE TO WS-FUNC-DATE
           STRING WS-FUNC-DATE(1:4) "-" WS-FUNC-DATE(5:2) "-"
                  WS-FUNC-DATE(7:2)
                  DELIMITED BY SIZE INTO WS-TODAY.

       INIT-THEME.
           IF WS-THEME = "green" OR WS-THEME = SPACES
               MOVE SPACES TO WS-ARG-VALUE
               ACCEPT WS-ARG-VALUE FROM ENVIRONMENT "CONSOLE_THEME"
               IF WS-ARG-VALUE NOT = SPACES
                   MOVE WS-ARG-VALUE(1:8) TO WS-THEME
               END-IF
           END-IF
           IF FUNCTION LOWER-CASE(FUNCTION TRIM(WS-THEME)) = "amber"
               MOVE "amber" TO WS-THEME
           ELSE
               MOVE "green" TO WS-THEME
           END-IF
           PERFORM SET-THEME
           PERFORM BUILD-HBAR.

       SET-THEME.
           IF WS-THEME = "amber"
               MOVE "38;5;214"   TO WS-CLR-BASE
               MOVE "1;38;5;214" TO WS-CLR-HI
               MOVE "7;38;5;214" TO WS-CLR-REV
           ELSE
               MOVE "32"   TO WS-CLR-BASE
               MOVE "1;32" TO WS-CLR-HI
               MOVE "7;32" TO WS-CLR-REV
           END-IF.

       TOGGLE-THEME.
           IF WS-THEME = "amber"
               MOVE "green" TO WS-THEME
           ELSE
               MOVE "amber" TO WS-THEME
           END-IF
           PERFORM SET-THEME.

       BUILD-HBAR.
           MOVE SPACES TO WS-HBAR
           MOVE 1 TO WS-HB-PTR
           PERFORM 78 TIMES
               MOVE WS-BX-H TO WS-HBAR(WS-HB-PTR:3)
               ADD 3 TO WS-HB-PTR
           END-PERFORM.

       REVS-INIT-ENV.
           MOVE SPACES TO WS-ARG-VALUE
           ACCEPT WS-ARG-VALUE FROM ENVIRONMENT "CONSOLE_ALLOW_WRITE"
           IF WS-ARG-VALUE(1:3) = "YES"
               MOVE "Y" TO WS-ALLOW-WRITE
           ELSE
               MOVE "N" TO WS-ALLOW-WRITE
           END-IF
           MOVE SPACES TO WS-OPERATOR
           ACCEPT WS-OPERATOR FROM ENVIRONMENT "CONSOLE_OPERATOR_ID"
           INSPECT WS-OPERATOR REPLACING ALL X"0D" BY SPACE
           INSPECT WS-OPERATOR REPLACING ALL X"0A" BY SPACE
           INSPECT WS-OPERATOR REPLACING ALL X"09" BY SPACE
           MOVE FUNCTION TRIM(WS-OPERATOR) TO WS-OPERATOR
           MOVE SPACES TO WS-REVS-SCRIPT
           ACCEPT WS-REVS-SCRIPT FROM ENVIRONMENT "CONSOLE_REVS_SCRIPT"
           IF WS-REVS-SCRIPT = SPACES
               MOVE "/workspace/console/scripts/run-reverse.sh"
                   TO WS-REVS-SCRIPT
           END-IF
           MOVE SPACES TO WS-ARG-VALUE
           ACCEPT WS-ARG-VALUE FROM ENVIRONMENT "CONSOLE_REVS_DIR"
           IF WS-ARG-VALUE NOT = SPACES
               MOVE WS-ARG-VALUE TO WS-REVS-DIR
           END-IF
           STRING FUNCTION TRIM(WS-REVS-DIR) "/request.txt"
                  DELIMITED BY SIZE INTO WS-REQ-PATH
           STRING FUNCTION TRIM(WS-REVS-DIR) "/result.txt"
                  DELIMITED BY SIZE INTO WS-RES-PATH
           MOVE SPACES TO WS-POST-SCRIPT
           ACCEPT WS-POST-SCRIPT FROM ENVIRONMENT "CONSOLE_POST_SCRIPT"
           IF WS-POST-SCRIPT = SPACES
               MOVE "/workspace/console/scripts/run-post.sh"
                   TO WS-POST-SCRIPT
           END-IF
           MOVE SPACES TO WS-ARG-VALUE
           ACCEPT WS-ARG-VALUE FROM ENVIRONMENT "CONSOLE_POST_DIR"
           IF WS-ARG-VALUE NOT = SPACES
               MOVE WS-ARG-VALUE TO WS-POST-DIR
           END-IF
           STRING FUNCTION TRIM(WS-POST-DIR) "/request.txt"
                  DELIMITED BY SIZE INTO WS-PREQ-PATH
           STRING FUNCTION TRIM(WS-POST-DIR) "/result.txt"
                  DELIMITED BY SIZE INTO WS-PRES-PATH.

       LOAD-MESSAGES.
           MOVE SPACES TO WS-MSG-DIR
           ACCEPT WS-MSG-DIR FROM ENVIRONMENT "CONSOLE_MSG_DIR"
           IF WS-MSG-DIR = SPACES
               MOVE "/workspace/console/msg" TO WS-MSG-DIR
           END-IF
           IF WS-LANG NOT = "ja" AND WS-LANG NOT = "en"
               MOVE "ja" TO WS-LANG
           END-IF
           STRING FUNCTION TRIM(WS-MSG-DIR) "/labels-" WS-LANG ".txt"
                  DELIMITED BY SIZE INTO WS-MSG-PATH
           MOVE "N" TO WS-MSG-EOF
           OPEN INPUT MSG-FILE
           IF WS-MSG-FS NOT = "00"
               DISPLAY "[ERROR] cannot open " FUNCTION TRIM(WS-MSG-PATH)
                       UPON SYSERR
               MOVE 12 TO WS-RETURN-CODE
               GO TO PROGRAM-EXIT
           END-IF
           PERFORM UNTIL WS-MSG-EOF = "Y"
               READ MSG-FILE
                   AT END MOVE "Y" TO WS-MSG-EOF
                   NOT AT END
                       MOVE SPACES TO WS-MKEY WS-MVAL
                       MOVE 1 TO WS-MPTR
                       UNSTRING MSG-REC DELIMITED BY "="
                           INTO WS-MKEY WITH POINTER WS-MPTR
                       IF WS-MPTR > 1 AND WS-MPTR <= 200
                           MOVE MSG-REC(WS-MPTR:) TO WS-MVAL
                           PERFORM STORE-LABEL
                       END-IF
               END-READ
           END-PERFORM
           CLOSE MSG-FILE
           PERFORM INIT-STEP-STATES.

       STORE-LABEL.
           EVALUATE FUNCTION TRIM(WS-MKEY)
               WHEN "APPTITLE"     MOVE WS-MVAL TO LBL-APPTITLE
               WHEN "MENUHEAD"     MOVE WS-MVAL TO LBL-MENUHEAD
               WHEN "M_BMON"       MOVE WS-MVAL TO LBL-M-BMON
               WHEN "M_JRNL"       MOVE WS-MVAL TO LBL-M-JRNL
               WHEN "M_ACCT"       MOVE WS-MVAL TO LBL-M-ACCT
               WHEN "M_AUDT"       MOVE WS-MVAL TO LBL-M-AUDT
               WHEN "TRANPROMPT"   MOVE WS-MVAL TO LBL-TRANPROMPT
               WHEN "PF_MENU"      MOVE WS-MVAL TO LBL-PF-MENU
               WHEN "PF_BMON"      MOVE WS-MVAL TO LBL-PF-BMON
               WHEN "PF_JRNL"      MOVE WS-MVAL TO LBL-PF-JRNL
               WHEN "BMONTITLE"    MOVE WS-MVAL TO LBL-BMONTITLE
               WHEN "JRNLTITLE"    MOVE WS-MVAL TO LBL-JRNLTITLE
               WHEN "COL_STEP"     MOVE WS-MVAL TO LBL-COL-STEP
               WHEN "COL_BIZ"      MOVE WS-MVAL TO LBL-COL-BIZ
               WHEN "COL_STATE"    MOVE WS-MVAL TO LBL-COL-STATE
               WHEN "COL_CNT"      MOVE WS-MVAL TO LBL-COL-CNT
