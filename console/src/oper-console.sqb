       IDENTIFICATION DIVISION.
       PROGRAM-ID. OPER-CONSOLE.
       ENVIRONMENT DIVISION.
       CONFIGURATION SECTION.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT MSG-FILE ASSIGN TO WS-MSG-PATH
               ORGANIZATION IS LINE SEQUENTIAL
               FILE STATUS  IS WS-MSG-FS.
           SELECT REVREQ-FILE ASSIGN TO WS-REQ-PATH
               ORGANIZATION IS LINE SEQUENTIAL
               FILE STATUS  IS WS-REQ-FS.
           SELECT REVRES-FILE ASSIGN TO WS-RES-PATH
               ORGANIZATION IS LINE SEQUENTIAL
               FILE STATUS  IS WS-RES-FS.
          SELECT POSTREQ-FILE ASSIGN TO WS-PREQ-PATH
              ORGANIZATION IS LINE SEQUENTIAL
              FILE STATUS  IS WS-PREQ-FS.
          SELECT POSTRES-FILE ASSIGN TO WS-PRES-PATH
              ORGANIZATION IS LINE SEQUENTIAL
              FILE STATUS  IS WS-PRES-FS.
          SELECT SCENRES-FILE ASSIGN TO WS-SCEN-RES-PATH
              ORGANIZATION IS LINE SEQUENTIAL
              FILE STATUS  IS WS-SCRES-FS.
          SELECT SCENKEY-FILE ASSIGN TO WS-SCEN-KEY-PATH
              ORGANIZATION IS LINE SEQUENTIAL
              FILE STATUS  IS WS-SCKEY-FS.

       DATA DIVISION.
       FILE SECTION.
       FD  MSG-FILE.
       01  MSG-REC                   PIC X(200).

       FD  REVREQ-FILE.
