               WHEN "BR_STEP"      MOVE WS-MVAL TO LBL-BR-STEP
               WHEN "BR_TXNS"      MOVE WS-MVAL TO LBL-BR-TXNS
               WHEN "BR_ERRS"      MOVE WS-MVAL TO LBL-BR-ERRS
               WHEN "BR_START"     MOVE WS-MVAL TO LBL-BR-START
               WHEN "BR_EMPTY"     MOVE WS-MVAL TO LBL-BR-EMPTY
               WHEN "M_SCEN"       MOVE WS-MVAL TO LBL-M-SCEN
               WHEN "SCENTITLE"    MOVE WS-MVAL TO LBL-SCENTITLE
               WHEN "PF_SCEN"      MOVE WS-MVAL TO LBL-PF-SCEN
               WHEN "SC_HDR"       MOVE WS-MVAL TO LBL-SC-HDR
               WHEN "SC_DESC_RECON" MOVE WS-MVAL TO LBL-SC-DESC-RECON
               WHEN "SC_DESC_CONC" MOVE WS-MVAL TO LBL-SC-DESC-CONC
               WHEN "SC_DESC_SMOKE" MOVE WS-MVAL TO LBL-SC-DESC-SMOKE
               WHEN "SC_RUNNING"   MOVE WS-MVAL TO LBL-SC-RUNNING
               WHEN "SC_OK"        MOVE WS-MVAL TO LBL-SC-OK
               WHEN "SC_FAIL"      MOVE WS-MVAL TO LBL-SC-FAIL
               WHEN "SC_SCN"       MOVE WS-MVAL TO LBL-SC-SCN
               WHEN "SC_ELAPSED"   MOVE WS-MVAL TO LBL-SC-ELAPSED
               WHEN "SC_GATE"      MOVE WS-MVAL TO LBL-SC-GATE
               WHEN "OIA_SYS"      MOVE WS-MVAL TO LBL-OIA-SYS
               WHEN "OIA_READY"    MOVE WS-MVAL TO LBL-OIA-READY
               WHEN "M_THEME"      MOVE WS-MVAL TO LBL-M-THEME
               WHEN "WATCHING"     MOVE WS-MVAL TO LBL-WATCHING
               WHEN "PF_BRUN"      MOVE WS-MVAL TO LBL-PF-BRUN
               WHEN OTHER          CONTINUE
           END-EVALUATE.

       INIT-STEP-STATES.
           MOVE LBL-ST-WAIT TO WS-ST-S10 WS-ST-S11 WS-ST-S12
                               WS-ST-S13 WS-ST-S16 WS-ST-S17
           MOVE SPACES TO WS-CNT-S10 WS-CNT-S11 WS-CNT-S12
           MOVE LBL-READY TO WS-BMON-STATUS
           MOVE SPACES TO WS-BAL-IND
           MOVE 0 TO WS-DR-DISP WS-CR-DISP.

       DB-CONNECT.
           MOVE "banking" TO HV-DB-NAME
           MOVE "cobol"   TO HV-DB-USER
           MOVE "cobol"   TO HV-DB-PASS
           EXEC SQL
               CONNECT :HV-DB-USER IDENTIFIED BY :HV-DB-PASS
                   USING :HV-DB-NAME
           END-EXEC
           IF SQLCODE = 0
               SET WS-CONNECTED TO TRUE
           END-IF.

       DB-DISCONNECT.
           IF WS-CONNECTED
               EXEC SQL DISCONNECT ALL END-EXEC
               MOVE "N" TO WS-CONN-FLAG
           END-IF.

       MENU-LOOP.
           PERFORM UNTIL WS-EXIT-NOW
               IF WS-PENDING-TRAN NOT = SPACES
                   MOVE WS-PENDING-TRAN TO WS-TRAN-IN
                   MOVE SPACES TO WS-PENDING-TRAN
                   PERFORM DISPATCH-TRAN
               ELSE
                   MOVE SPACES TO WS-TRAN-IN
                   MOVE SPACES TO WS-KEY
                   MOVE LBL-READY TO WS-STATUS-MSG
                   PERFORM RENDER-MENU
                   PERFORM READ-TRAN
                   IF WS-TRAN-IN = SPACES
                       SET WS-EXIT-NOW TO TRUE
                   ELSE
                       PERFORM DISPATCH-TRAN
                   END-IF
               END-IF
           END-PERFORM.

       RENDER-MENU.
           IF SCREEN-ON
               PERFORM RENDER-MENU-ANSI
           ELSE
               DISPLAY " "
               DISPLAY "==== " FUNCTION TRIM(LBL-APPTITLE) " ===="
               DISPLAY "  BMON  " FUNCTION TRIM(LBL-M-BMON)
               DISPLAY "  JRNL  " FUNCTION TRIM(LBL-M-JRNL)
               DISPLAY "  REVS  " FUNCTION TRIM(LBL-M-REVS)
               DISPLAY "  POST  " FUNCTION TRIM(LBL-M-POST)
               DISPLAY "  BRUN  " FUNCTION TRIM(LBL-M-BRUN)
               DISPLAY "  SCEN  " FUNCTION TRIM(LBL-M-SCEN)
               DISPLAY "  " FUNCTION TRIM(LBL-TRANPROMPT) " "
                       NO ADVANCING
           END-IF.

       RENDER-MENU-ANSI.
          PERFORM ANSI-CLEAR
         PERFORM DRAW-FRAME
         MOVE WS-CLR-BASE TO WS-PUT-COLOR
         MOVE 1 TO WS-AT-ROW  MOVE 3 TO WS-AT-COL
         MOVE "PBNK001" TO WS-PUT-TEXT  PERFORM ANSI-PUT
         MOVE WS-CLR-HI TO WS-PUT-COLOR
         MOVE 1 TO WS-AT-ROW  MOVE 18 TO WS-AT-COL
         MOVE LBL-APPTITLE TO WS-PUT-TEXT  PERFORM ANSI-PUT
         MOVE WS-CLR-BASE TO WS-PUT-COLOR
         MOVE 1 TO WS-AT-ROW  MOVE 69 TO WS-AT-COL
         MOVE WS-TODAY TO WS-PUT-TEXT  PERFORM ANSI-PUT
         MOVE 2 TO WS-SEP-ROW
         PERFORM DRAW-SEP
         MOVE 4 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
          MOVE LBL-MENUHEAD TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 6 TO WS-AT-ROW  MOVE 6 TO WS-AT-COL
          MOVE "BMON" TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 6 TO WS-AT-ROW  MOVE 12 TO WS-AT-COL
          MOVE LBL-M-BMON TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 7 TO WS-AT-ROW  MOVE 6 TO WS-AT-COL
          MOVE "JRNL" TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 7 TO WS-AT-ROW  MOVE 12 TO WS-AT-COL
          MOVE LBL-M-JRNL TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 8 TO WS-AT-ROW  MOVE 6 TO WS-AT-COL
          MOVE "ACCT" TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 8 TO WS-AT-ROW  MOVE 12 TO WS-AT-COL
          MOVE LBL-M-ACCT TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 9 TO WS-AT-ROW  MOVE 6 TO WS-AT-COL
          MOVE "CUST" TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 9 TO WS-AT-ROW  MOVE 12 TO WS-AT-COL
          MOVE LBL-M-CUST TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 10 TO WS-AT-ROW  MOVE 6 TO WS-AT-COL
          MOVE "HIST" TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 10 TO WS-AT-ROW  MOVE 12 TO WS-AT-COL
          MOVE LBL-M-HIST TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 11 TO WS-AT-ROW  MOVE 6 TO WS-AT-COL
          MOVE "AUDT" TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 11 TO WS-AT-ROW  MOVE 12 TO WS-AT-COL
          MOVE LBL-M-AUDT TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 12 TO WS-AT-ROW  MOVE 6 TO WS-AT-COL
          MOVE "REVS" TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 12 TO WS-AT-ROW  MOVE 12 TO WS-AT-COL
          MOVE LBL-M-REVS TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 13 TO WS-AT-ROW  MOVE 6 TO WS-AT-COL
          MOVE "POST" TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 13 TO WS-AT-ROW  MOVE 12 TO WS-AT-COL
          MOVE LBL-M-POST TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 14 TO WS-AT-ROW  MOVE 6 TO WS-AT-COL
          MOVE "BRUN" TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 14 TO WS-AT-ROW  MOVE 12 TO WS-AT-COL
          MOVE LBL-M-BRUN TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 15 TO WS-AT-ROW  MOVE 6 TO WS-AT-COL
          MOVE "SCEN" TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 15 TO WS-AT-ROW  MOVE 12 TO WS-AT-COL
          MOVE LBL-M-SCEN TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 16 TO WS-AT-ROW  MOVE 6 TO WS-AT-COL
          MOVE LBL-TRANPROMPT TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE WS-CLR-BASE TO WS-PUT-COLOR
          MOVE 18 TO WS-AT-ROW  MOVE 6 TO WS-AT-COL
          MOVE LBL-M-THEME TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 22 TO WS-SEP-ROW
          PERFORM DRAW-SEP
          MOVE WS-CLR-REV TO WS-PUT-COLOR
          MOVE 23 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
          MOVE LBL-PF-MENU TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 23 TO WS-AT-ROW  MOVE 64 TO WS-AT-COL
          MOVE WS-STATUS-MSG TO WS-PUT-TEXT  PERFORM ANSI-PUT
          PERFORM RENDER-OIA.

       READ-TRAN.
          MOVE SPACES TO WS-TRAN-IN
          PERFORM PG-COMMIT
          IF SCREEN-ON
              MOVE 16 TO WS-AT-ROW  MOVE 18 TO WS-AT-COL
              PERFORM ANSI-CURSOR-AT
              PERFORM ANSI-SHOW-CURSOR
          END-IF
          ACCEPT WS-TRAN-IN
          INSPECT WS-TRAN-IN REPLACING ALL X"0D" BY SPACE
          INSPECT WS-TRAN-IN REPLACING ALL X"0A" BY SPACE
          INSPECT WS-TRAN-IN REPLACING ALL X"09" BY SPACE
          MOVE FUNCTION UPPER-CASE(WS-TRAN-IN) TO WS-TRAN-IN.

       DISPATCH-TRAN.
           MOVE SPACES TO WS-ERR-MSG
           EVALUATE FUNCTION TRIM(WS-TRAN-IN)
               WHEN "BMON" PERFORM BMON-TRAN
               WHEN "JRNL" PERFORM JRNL-TRAN
               WHEN "EXIT"
               WHEN "QUIT"
                   SET WS-EXIT-NOW TO TRUE
               WHEN "ACCT" PERFORM ACCT-TRAN
               WHEN "CUST" PERFORM CUST-TRAN
               WHEN "HIST" PERFORM HIST-TRAN
               WHEN "AUDT" PERFORM AUDT-TRAN
               WHEN "REVS" PERFORM REVS-TRAN
               WHEN "POST" PERFORM POST-TRAN
               WHEN "BRUN" PERFORM BRUN-TRAN
               WHEN "SCEN" PERFORM SCEN-TRAN
               WHEN "THEM"
               WHEN "THM"
                   PERFORM TOGGLE-THEME
               WHEN SPACES
                   CONTINUE
               WHEN OTHER
                   MOVE LBL-INVALIDTRAN TO WS-ERR-MSG
                   IF NOT SCREEN-ON
                       DISPLAY FUNCTION TRIM(LBL-INVALIDTRAN)
                   END-IF
           END-EVALUATE.

       BMON-TRAN.
           PERFORM BMON-SETUP
           PERFORM INIT-STEP-STATES
           MOVE "Y" TO WS-BMON-OK
           IF SCREEN-ON
               PERFORM ANSI-HIDE-CURSOR
           END-IF
           PERFORM BMON-RENDER
           PERFORM BMON-RUN-PIPELINE
           PERFORM BMON-REFRESH-TOTALS
           IF WS-BMON-OK = "Y"
               MOVE LBL-DONEMSG TO WS-BMON-STATUS
           ELSE
               MOVE LBL-ST-FAIL TO WS-BMON-STATUS
           END-IF
           PERFORM BMON-RENDER
           IF SCREEN-ON
               PERFORM BMON-WAIT-KEY
           END-IF.

       BMON-SETUP.
           ACCEPT WS-STAGE-SCRIPT
               FROM ENVIRONMENT "CONSOLE_STAGE_SCRIPT"
           IF WS-STAGE-SCRIPT = SPACES
               MOVE "/workspace/console/scripts/run-stage.sh"
                   TO WS-STAGE-SCRIPT
           END-IF
           MOVE "/tmp/console-demo" TO WS-WORKDIR.

       BMON-RUN-PIPELINE.
          PERFORM PG-COMMIT
          PERFORM BMON-EXEC-VERB-RESET
           IF WS-CMD-RC NOT = 0
               PERFORM BMON-FAIL-ABORT
               EXIT PARAGRAPH
           END-IF
           PERFORM BMON-EXEC-VERB-FIXTURE
           IF WS-CMD-RC NOT = 0
               PERFORM BMON-FAIL-ABORT
               EXIT PARAGRAPH
           END-IF
           MOVE LBL-ST-RUN TO WS-ST-S10
           MOVE LBL-RUNNING TO WS-BMON-STATUS
           PERFORM BMON-RENDER
           PERFORM BMON-PAUSE
           MOVE "s10" TO WS-CMD
           PERFORM BMON-RUN-STAGE
           IF WS-CMD-RC = 0
               MOVE LBL-ST-DONE TO WS-ST-S10
           ELSE
               MOVE LBL-ST-FAIL TO WS-ST-S10
               MOVE "N" TO WS-BMON-OK
           END-IF
           PERFORM BMON-RENDER
           PERFORM BMON-PAUSE
           IF WS-BMON-OK NOT = "Y"
               EXIT PARAGRAPH
           END-IF
           MOVE LBL-ST-RUN TO WS-ST-S11
           PERFORM BMON-RENDER
           PERFORM BMON-PAUSE
           MOVE "s11" TO WS-CMD
           PERFORM BMON-RUN-STAGE
           IF WS-CMD-RC = 0
               MOVE LBL-ST-DONE TO WS-ST-S11
           ELSE
               MOVE LBL-ST-FAIL TO WS-ST-S11
               MOVE "N" TO WS-BMON-OK
           END-IF
           PERFORM BMON-RENDER
           PERFORM BMON-PAUSE
           IF WS-BMON-OK NOT = "Y"
               EXIT PARAGRAPH
           END-IF
           MOVE LBL-ST-RUN TO WS-ST-S12
           PERFORM BMON-RENDER
           PERFORM BMON-PAUSE
           MOVE "s12" TO WS-CMD
           PERFORM BMON-RUN-STAGE
           IF WS-CMD-RC = 0
               MOVE LBL-ST-DONE TO WS-ST-S12
           ELSE
               MOVE LBL-ST-FAIL TO WS-ST-S12
               MOVE "N" TO WS-BMON-OK
           END-IF
           PERFORM BMON-COUNT-POSTED
           PERFORM BMON-RENDER
           PERFORM BMON-PAUSE.

       BMON-EXEC-VERB-RESET.
           MOVE SPACES TO WS-CMD
           STRING "bash " FUNCTION TRIM(WS-STAGE-SCRIPT)
                  " reset " FUNCTION TRIM(WS-WORKDIR)
                  " " WS-DEMO-BATCH " " WS-DEMO-BDATE
                  DELIMITED BY SIZE INTO WS-CMD
           CALL "SYSTEM" USING WS-CMD
           MOVE RETURN-CODE TO WS-CMD-RC.

       BMON-EXEC-VERB-FIXTURE.
           MOVE SPACES TO WS-CMD
           STRING "bash " FUNCTION TRIM(WS-STAGE-SCRIPT)
                  " fixture " FUNCTION TRIM(WS-WORKDIR)
                  " " WS-DEMO-BATCH " " WS-DEMO-BDATE
                  DELIMITED BY SIZE INTO WS-CMD
           CALL "SYSTEM" USING WS-CMD
           MOVE RETURN-CODE TO WS-CMD-RC.

       BMON-RUN-STAGE.
           MOVE FUNCTION TRIM(WS-CMD) TO WS-MKEY
           MOVE SPACES TO WS-CMD
           STRING "bash " FUNCTION TRIM(WS-STAGE-SCRIPT)
                  " " FUNCTION TRIM(WS-MKEY)
                  " " FUNCTION TRIM(WS-WORKDIR)
                  " " WS-DEMO-BATCH " " WS-DEMO-BDATE
                  DELIMITED BY SIZE INTO WS-CMD
           CALL "SYSTEM" USING WS-CMD
           MOVE RETURN-CODE TO WS-CMD-RC.

       BMON-FAIL-ABORT.
           MOVE "N" TO WS-BMON-OK
           MOVE LBL-ST-FAIL TO WS-BMON-STATUS
           PERFORM BMON-RENDER.

       BMON-PAUSE.
           IF SCREEN-ON
               CALL "CBL_OC_NANOSLEEP" USING 450000000
           END-IF.

       BMON-COUNT-POSTED.
           PERFORM PG-COMMIT
           MOVE WS-DEMO-BDATE-PG TO HV-BDATE
           EXEC SQL
               SELECT COUNT(*) INTO :HV-CNT FROM transactions
                WHERE business_date = CAST(:HV-BDATE AS DATE)
           END-EXEC
           MOVE HV-CNT TO WS-CNT-EDIT
           MOVE SPACES TO WS-CNT-S12
           STRING "txn " FUNCTION TRIM(WS-CNT-EDIT)
                  DELIMITED BY SIZE INTO WS-CNT-S12.

       BMON-REFRESH-TOTALS.
           PERFORM PG-COMMIT
           MOVE WS-DEMO-BDATE-PG TO HV-BDATE
           EXEC SQL
               SELECT COALESCE(SUM(debit_jpy),0) INTO :HV-SUM
                 FROM postings
                WHERE business_date = CAST(:HV-BDATE AS DATE)
           END-EXEC
           MOVE HV-SUM TO WS-DR-DISP
           EXEC SQL
               SELECT COALESCE(SUM(credit_jpy),0) INTO :HV-SUM
                 FROM postings
                WHERE business_date = CAST(:HV-BDATE AS DATE)
           END-EXEC
           MOVE HV-SUM TO WS-CR-DISP
           IF WS-DR-DISP = WS-CR-DISP
               MOVE LBL-BALOK TO WS-BAL-IND
           ELSE
               MOVE LBL-BALNG TO WS-BAL-IND
           END-IF.

       PG-COMMIT.
           EXEC SQL COMMIT END-EXEC.

       ANSI-CLEAR.
          DISPLAY WS-ESC "[0m" WS-ESC "[2J" WS-ESC "[H"
                  WITH NO ADVANCING.

       ANSI-CURSOR-AT.
          DISPLAY WS-ESC "[" WS-AT-ROW ";" WS-AT-COL "H"
                  WITH NO ADVANCING.

       ANSI-PUT.
          DISPLAY WS-ESC "[" WS-AT-ROW ";" WS-AT-COL "H"
                  WS-ESC "[" FUNCTION TRIM(WS-PUT-COLOR) "m"
                  FUNCTION TRIM(WS-PUT-TEXT)
                  WS-ESC "[0m"
                  WITH NO ADVANCING.

       ANSI-HIDE-CURSOR.
          DISPLAY WS-ESC "[?25l" WITH NO ADVANCING.

       ANSI-SHOW-CURSOR.
          DISPLAY WS-ESC "[?25h" WITH NO ADVANCING.

       ANSI-RESET.
          DISPLAY WS-ESC "[0m" WS-ESC "[?25h" WS-ESC "[24;1H"
                  WITH NO ADVANCING.

       BMON-RENDER.
           IF SCREEN-ON
               PERFORM BMON-RENDER-ANSI
           ELSE
               DISPLAY "[BMON] 10 " FUNCTION TRIM(WS-ST-S10)
                       " | 11 " FUNCTION TRIM(WS-ST-S11)
                       " | 12 " FUNCTION TRIM(WS-ST-S12)
                       " | " FUNCTION TRIM(WS-CNT-S12)
           END-IF.

       BMON-RENDER-ANSI.
          PERFORM ANSI-CLEAR
         PERFORM DRAW-FRAME
         MOVE WS-CLR-BASE TO WS-PUT-COLOR
         MOVE 1 TO WS-AT-ROW  MOVE 3 TO WS-AT-COL
         MOVE "PBNK-BMON" TO WS-PUT-TEXT  PERFORM ANSI-PUT
         MOVE WS-CLR-HI TO WS-PUT-COLOR
         MOVE 1 TO WS-AT-ROW  MOVE 18 TO WS-AT-COL
         MOVE LBL-BMONTITLE TO WS-PUT-TEXT  PERFORM ANSI-PUT
         MOVE WS-CLR-BASE TO WS-PUT-COLOR
         MOVE 1 TO WS-AT-ROW  MOVE 69 TO WS-AT-COL
         MOVE WS-DEMO-BDATE-PG TO WS-PUT-TEXT  PERFORM ANSI-PUT
         MOVE 2 TO WS-SEP-ROW  PERFORM DRAW-SEP
          MOVE 4 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
          MOVE LBL-COL-STEP TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 4 TO WS-AT-ROW  MOVE 12 TO WS-AT-COL
          MOVE LBL-COL-BIZ TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 4 TO WS-AT-ROW  MOVE 50 TO WS-AT-COL
          MOVE LBL-COL-STATE TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 4 TO WS-AT-ROW  MOVE 66 TO WS-AT-COL
          MOVE LBL-COL-CNT TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 5 TO WS-SEP-ROW  PERFORM DRAW-SEP
          MOVE "10" TO WS-STEP-NO  MOVE 6 TO WS-AT-ROW
          MOVE LBL-S10 TO WS-PUT-TEXT  PERFORM BMON-ROW-ANSI
          MOVE WS-ST-S10 TO WS-PUT-TEXT  PERFORM BMON-STATE-ANSI
          MOVE WS-CNT-S10 TO WS-PUT-TEXT  PERFORM BMON-CNT-ANSI
          MOVE "11" TO WS-STEP-NO  MOVE 7 TO WS-AT-ROW
          MOVE LBL-S11 TO WS-PUT-TEXT  PERFORM BMON-ROW-ANSI
          MOVE WS-ST-S11 TO WS-PUT-TEXT  PERFORM BMON-STATE-ANSI
          MOVE WS-CNT-S11 TO WS-PUT-TEXT  PERFORM BMON-CNT-ANSI
          MOVE "12" TO WS-STEP-NO  MOVE 8 TO WS-AT-ROW
          MOVE LBL-S12 TO WS-PUT-TEXT  PERFORM BMON-ROW-ANSI
          MOVE WS-ST-S12 TO WS-PUT-TEXT  PERFORM BMON-STATE-ANSI
          MOVE WS-CNT-S12 TO WS-PUT-TEXT  PERFORM BMON-CNT-ANSI
          MOVE "13" TO WS-STEP-NO  MOVE 9 TO WS-AT-ROW
          MOVE LBL-S13 TO WS-PUT-TEXT  PERFORM BMON-ROW-ANSI
          MOVE WS-ST-S13 TO WS-PUT-TEXT  PERFORM BMON-STATE-ANSI
          MOVE "16" TO WS-STEP-NO  MOVE 10 TO WS-AT-ROW
          MOVE LBL-S16 TO WS-PUT-TEXT  PERFORM BMON-ROW-ANSI
          MOVE WS-ST-S16 TO WS-PUT-TEXT  PERFORM BMON-STATE-ANSI
          MOVE "17" TO WS-STEP-NO  MOVE 11 TO WS-AT-ROW
          MOVE LBL-S17 TO WS-PUT-TEXT  PERFORM BMON-ROW-ANSI
          MOVE WS-ST-S17 TO WS-PUT-TEXT  PERFORM BMON-STATE-ANSI
          MOVE 19 TO WS-SEP-ROW  PERFORM DRAW-SEP
          MOVE 20 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
          MOVE LBL-DRLABEL TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE WS-DR-DISP TO WS-DRCR-TEXT
          MOVE 20 TO WS-AT-ROW  MOVE 28 TO WS-AT-COL
          MOVE WS-DRCR-TEXT TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 20 TO WS-AT-ROW  MOVE 48 TO WS-AT-COL
          MOVE LBL-CRLABEL TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 20 TO WS-AT-ROW  MOVE 64 TO WS-AT-COL
          MOVE WS-BAL-IND TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 22 TO WS-SEP-ROW  PERFORM DRAW-SEP
          MOVE WS-CLR-REV TO WS-PUT-COLOR
          MOVE 23 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
          MOVE LBL-PF-BMON TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 23 TO WS-AT-ROW  MOVE 60 TO WS-AT-COL
          MOVE WS-BMON-STATUS TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE WS-CLR-BASE TO WS-PUT-COLOR
          PERFORM RENDER-OIA.

       BMON-ROW-ANSI.
          MOVE WS-PUT-TEXT TO WS-ROW-BIZ
          MOVE WS-AT-ROW TO WS-ROW-SAVE
          MOVE 3 TO WS-AT-COL
          MOVE WS-STEP-NO TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE WS-ROW-SAVE TO WS-AT-ROW
          MOVE 12 TO WS-AT-COL
          MOVE WS-ROW-BIZ TO WS-PUT-TEXT  PERFORM ANSI-PUT.

       BMON-STATE-ANSI.
          MOVE WS-AT-ROW TO WS-ROW-SAVE
          MOVE 50 TO WS-AT-COL  PERFORM ANSI-PUT
          MOVE WS-ROW-SAVE TO WS-AT-ROW.

       BMON-CNT-ANSI.
          MOVE WS-AT-ROW TO WS-ROW-SAVE
          MOVE 66 TO WS-AT-COL  PERFORM ANSI-PUT
          MOVE WS-ROW-SAVE TO WS-AT-ROW.

       BMON-WAIT-KEY.
          PERFORM PG-COMMIT
          MOVE WS-CLR-BASE TO WS-PUT-COLOR
          MOVE 21 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
          MOVE LBL-PRESSENTER TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 21 TO WS-AT-ROW  MOVE 40 TO WS-AT-COL
          PERFORM ANSI-CURSOR-AT
          PERFORM ANSI-SHOW-CURSOR
          MOVE SPACES TO WS-TRAN-IN
          ACCEPT WS-TRAN-IN.

       JRNL-TRAN.
           MOVE 1 TO WS-PAGE
           PERFORM JRNL-COUNT
           PERFORM JRNL-LOAD-PAGE
           PERFORM JRNL-RENDER
           IF SCREEN-ON
               PERFORM JRNL-EVENT-LOOP
           END-IF.

       JRNL-COUNT.
           PERFORM PG-COMMIT
           EXEC SQL
               SELECT COUNT(*) INTO :HV-CNT FROM transactions
           END-EXEC
           MOVE HV-CNT TO WS-JTOTAL.

       JRNL-LOAD-PAGE.
           COMPUTE WS-OFFSET = (WS-PAGE - 1) * WS-PAGE-SIZE
           MOVE WS-OFFSET    TO HV-OFFSET
           MOVE WS-PAGE-SIZE TO HV-LIMIT
           PERFORM CLEAR-JROWS
           MOVE 0 TO WS-ROW-IDX
           PERFORM PG-COMMIT
           EXEC SQL
               DECLARE JCUR CURSOR FOR
               SELECT t.txn_id, t.category, t.amount_jpy,
                      COALESCE((SELECT p.account_number FROM postings p
                                 WHERE p.txn_id = t.txn_id
                                   AND p.debit_jpy > 0
                                 ORDER BY p.line_no LIMIT 1), ' '),
                      COALESCE((SELECT p.account_number FROM postings p
                                 WHERE p.txn_id = t.txn_id
                                   AND p.credit_jpy > 0
                                 ORDER BY p.line_no LIMIT 1), ' ')
                 FROM transactions t
                ORDER BY t.txn_id
               OFFSET :HV-OFFSET LIMIT :HV-LIMIT
           END-EXEC
           EXEC SQL OPEN JCUR END-EXEC
           PERFORM UNTIL SQLCODE NOT = 0
               EXEC SQL
                   FETCH JCUR INTO :HV-TXN, :HV-CAT, :HV-AMT,
                                   :HV-DR-ACCT, :HV-CR-ACCT
               END-EXEC
               IF SQLCODE = 0
                   ADD 1 TO WS-ROW-IDX
                   MOVE HV-TXN     TO JR-TXN(WS-ROW-IDX)
                   PERFORM MAP-CAT
                   MOVE WS-MVAL(1:10) TO JR-CAT(WS-ROW-IDX)
                   MOVE HV-DR-ACCT TO JR-DR(WS-ROW-IDX)
                   MOVE HV-CR-ACCT TO JR-CR(WS-ROW-IDX)
                   MOVE HV-AMT     TO JR-AMT(WS-ROW-IDX)
               END-IF
           END-PERFORM
           EXEC SQL CLOSE JCUR END-EXEC.

       MAP-CAT.
           EVALUATE HV-CAT
               WHEN "10" MOVE LBL-CAT10 TO WS-MVAL
               WHEN "20" MOVE LBL-CAT20 TO WS-MVAL
               WHEN "30" MOVE LBL-CAT30 TO WS-MVAL
               WHEN "40" MOVE LBL-CAT40 TO WS-MVAL
               WHEN OTHER MOVE LBL-CATRV TO WS-MVAL
           END-EVALUATE.

       CLEAR-JROWS.
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1 UNTIL WS-ROW-IDX > 10
               MOVE SPACES TO JR-TXN(WS-ROW-IDX) JR-CAT(WS-ROW-IDX)
                              JR-DR(WS-ROW-IDX)  JR-CR(WS-ROW-IDX)
               MOVE 0 TO JR-AMT(WS-ROW-IDX)
           END-PERFORM.

       JRNL-RENDER.
           MOVE SPACES TO WS-STATUS-MSG
           STRING FUNCTION TRIM(LBL-PAGEOF) " " WS-PAGE
                  DELIMITED BY SIZE INTO WS-STATUS-MSG
           IF SCREEN-ON
               PERFORM JRNL-RENDER-ANSI
           ELSE
               DISPLAY " "
               DISPLAY "== " FUNCTION TRIM(LBL-JRNLTITLE)
                       " (" FUNCTION TRIM(LBL-PAGEOF) " " WS-PAGE ")"
               DISPLAY LBL-JC-TXN " " LBL-JC-CAT " "
                       LBL-JC-DR " " LBL-JC-CR " " LBL-JC-AMT
               PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                       UNTIL WS-ROW-IDX > 10
                   IF JR-TXN(WS-ROW-IDX) NOT = SPACES
                       MOVE JR-AMT(WS-ROW-IDX) TO WS-PLAIN-AMT
                       DISPLAY JR-TXN(WS-ROW-IDX) " "
                               JR-CAT(WS-ROW-IDX) " "
                               JR-DR(WS-ROW-IDX) " "
                               JR-CR(WS-ROW-IDX) " "
                               FUNCTION TRIM(WS-PLAIN-AMT)
                   END-IF
               END-PERFORM
           END-IF.

       JRNL-RENDER-ANSI.
           PERFORM ANSI-CLEAR
           PERFORM DRAW-FRAME
           MOVE WS-CLR-BASE TO WS-PUT-COLOR
           MOVE 1 TO WS-AT-ROW  MOVE 3 TO WS-AT-COL
           MOVE "PBNK-JRNL" TO WS-PUT-TEXT  PERFORM ANSI-PUT
           MOVE WS-CLR-HI TO WS-PUT-COLOR
           MOVE 1 TO WS-AT-ROW  MOVE 18 TO WS-AT-COL
           MOVE LBL-JRNLTITLE TO WS-PUT-TEXT  PERFORM ANSI-PUT
           MOVE WS-CLR-BASE TO WS-PUT-COLOR
           MOVE 2 TO WS-SEP-ROW  PERFORM DRAW-SEP
           MOVE 4 TO WS-FLD-LINE  MOVE 2 TO WS-FLD-COL
           MOVE LBL-JC-TXN TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 4 TO WS-FLD-LINE  MOVE 22 TO WS-FLD-COL
           MOVE LBL-JC-CAT TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 4 TO WS-FLD-LINE  MOVE 32 TO WS-FLD-COL
           MOVE LBL-JC-DR TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 4 TO WS-FLD-LINE  MOVE 50 TO WS-FLD-COL
           MOVE LBL-JC-CR TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 4 TO WS-FLD-LINE  MOVE 70 TO WS-FLD-COL
           MOVE LBL-JC-AMT TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-SEP-ROW  PERFORM DRAW-SEP
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > 10
               IF JR-TXN(WS-ROW-IDX) NOT = SPACES
                   COMPUTE WS-FLD-LINE = 5 + WS-ROW-IDX
                   MOVE 2 TO WS-FLD-COL
                   MOVE JR-TXN(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 22 TO WS-FLD-COL
                   MOVE JR-CAT(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 32 TO WS-FLD-COL
                   MOVE JR-DR(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 50 TO WS-FLD-COL
                   MOVE JR-CR(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 68 TO WS-FLD-COL
                   MOVE JR-AMT(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
               END-IF
           END-PERFORM
           MOVE 21 TO WS-SEP-ROW  PERFORM DRAW-SEP
           MOVE WS-CLR-BASE TO WS-PUT-COLOR
           MOVE 22 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
           MOVE LBL-CMDPROMPT TO WS-PUT-TEXT  PERFORM ANSI-PUT
           MOVE WS-CLR-REV TO WS-PUT-COLOR
           MOVE 23 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
           MOVE LBL-PF-JRNL TO WS-PUT-TEXT  PERFORM ANSI-PUT
           MOVE 23 TO WS-AT-ROW  MOVE 64 TO WS-AT-COL
           MOVE WS-STATUS-MSG TO WS-PUT-TEXT  PERFORM ANSI-PUT
           MOVE WS-CLR-BASE TO WS-PUT-COLOR
           PERFORM RENDER-OIA.

       JRNL-EVENT-LOOP.
           MOVE "N" TO WS-EXIT-FLAG
           PERFORM UNTIL WS-EXIT-FLAG = "Y"
               PERFORM INQ-READ-CMD
               EVALUATE WS-CMD-NORM
                   WHEN SPACES
                   WHEN "B"
                   WHEN "BACK"
                   WHEN "MENU"
                   WHEN "EXIT"
                   WHEN "QUIT"
                       MOVE "Y" TO WS-EXIT-FLAG
                   WHEN "N"
                   WHEN "NEXT"
                       IF (WS-PAGE * WS-PAGE-SIZE) < WS-JTOTAL
                           ADD 1 TO WS-PAGE
                           PERFORM JRNL-LOAD-PAGE
                           PERFORM JRNL-RENDER
                       END-IF
                   WHEN "P"
                   WHEN "PREV"
                       IF WS-PAGE > 1
                           SUBTRACT 1 FROM WS-PAGE
                           PERFORM JRNL-LOAD-PAGE
                           PERFORM JRNL-RENDER
                       END-IF
                   WHEN OTHER
                       PERFORM REVS-PARSE-ROW
                       IF WS-ROW-OK = "Y" AND
                          JR-TXN(WS-ROW-PICK) IS NUMERIC
                           MOVE JR-TXN(WS-ROW-PICK) TO WS-PREFILL-TXN
                           MOVE "REVS" TO WS-PENDING-TRAN
                           MOVE "Y" TO WS-EXIT-FLAG
                       ELSE
                           CONTINUE
                       END-IF
               END-EVALUATE
           END-PERFORM.

       NORMALIZE-KEY.
           MOVE FUNCTION TRIM(WS-KEY) TO WS-KEY.

       RENDER-FIELD.
          MOVE WS-CLR-BASE TO WS-PUT-COLOR
          MOVE WS-FLD-LINE TO WS-AT-ROW
          MOVE 4 TO WS-AT-COL
          MOVE WS-FLD-LBL TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE WS-FLD-LINE TO WS-AT-ROW
          MOVE 22 TO WS-AT-COL
          MOVE WS-FLD-VAL TO WS-PUT-TEXT  PERFORM ANSI-PUT.

       RENDER-AT.
          MOVE WS-FLD-LINE TO WS-AT-ROW
          MOVE WS-FLD-COL TO WS-AT-COL
          MOVE WS-FLD-VAL TO WS-PUT-TEXT
          PERFORM ANSI-PUT.

       RENDER-NOTFOUND-SCREEN.
          MOVE "1;31" TO WS-PUT-COLOR
          MOVE 6 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
          MOVE LBL-NOTFOUND TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE WS-CLR-BASE TO WS-PUT-COLOR.

       RENDER-HDR-ANSI.
          PERFORM ANSI-CLEAR
          PERFORM DRAW-FRAME
          MOVE WS-CLR-BASE TO WS-PUT-COLOR
          MOVE 1 TO WS-AT-ROW  MOVE 3 TO WS-AT-COL
          MOVE WS-SCR-PFX TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE WS-CLR-HI TO WS-PUT-COLOR
          MOVE 1 TO WS-AT-ROW  MOVE 18 TO WS-AT-COL
          MOVE WS-SCR-TITLE TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE WS-CLR-BASE TO WS-PUT-COLOR
          MOVE 1 TO WS-AT-ROW  MOVE 69 TO WS-AT-COL
          MOVE WS-TODAY TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 2 TO WS-SEP-ROW
          PERFORM DRAW-SEP.

       RENDER-INQ-FOOT-ANSI.
          MOVE 21 TO WS-SEP-ROW
          PERFORM DRAW-SEP
          MOVE WS-CLR-BASE TO WS-PUT-COLOR
          MOVE 22 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
          MOVE LBL-KEYPROMPT TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE WS-CLR-REV TO WS-PUT-COLOR
          MOVE 23 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
          MOVE WS-SCR-PF TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 23 TO WS-AT-ROW  MOVE 64 TO WS-AT-COL
          MOVE WS-STATUS-MSG TO WS-PUT-TEXT  PERFORM ANSI-PUT
          PERFORM RENDER-OIA
          MOVE WS-CLR-BASE TO WS-PUT-COLOR.

       DRAW-FRAME.
          MOVE WS-CLR-BASE TO WS-PUT-COLOR
          MOVE 1 TO WS-AT-ROW  MOVE 1 TO WS-AT-COL
          MOVE WS-BX-TL TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 1 TO WS-AT-ROW  MOVE 80 TO WS-AT-COL
          MOVE WS-BX-TR TO WS-PUT-TEXT  PERFORM ANSI-PUT
          PERFORM VARYING WS-FRAME-ROW FROM 2 BY 1
                  UNTIL WS-FRAME-ROW > 22
              MOVE WS-FRAME-ROW TO WS-AT-ROW  MOVE 1 TO WS-AT-COL
              MOVE WS-BX-V TO WS-PUT-TEXT  PERFORM ANSI-PUT
              MOVE WS-FRAME-ROW TO WS-AT-ROW  MOVE 80 TO WS-AT-COL
              MOVE WS-BX-V TO WS-PUT-TEXT  PERFORM ANSI-PUT
          END-PERFORM
          MOVE 23 TO WS-AT-ROW  MOVE 1 TO WS-AT-COL
          MOVE WS-BX-BL TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE 23 TO WS-AT-ROW  MOVE 80 TO WS-AT-COL
          MOVE WS-BX-BR TO WS-PUT-TEXT  PERFORM ANSI-PUT.

       DRAW-SEP.
          MOVE WS-CLR-BASE TO WS-PUT-COLOR
          MOVE WS-SEP-ROW TO WS-AT-ROW  MOVE 1 TO WS-AT-COL
          MOVE WS-BX-TEEL TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE WS-SEP-ROW TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
          MOVE WS-HBAR TO WS-PUT-TEXT  PERFORM ANSI-PUT
          MOVE WS-SEP-ROW TO WS-AT-ROW  MOVE 80 TO WS-AT-COL
          MOVE WS-BX-TEER TO WS-PUT-TEXT  PERFORM ANSI-PUT.

       BUILD-OIA-CLOCK.
          MOVE FUNCTION CURRENT-DATE TO WS-FUNC-DATE
          MOVE SPACES TO WS-OIA-CLOCK
          STRING WS-FUNC-DATE(1:4) "-" WS-FUNC-DATE(5:2) "-"
                 WS-FUNC-DATE(7:2) " "
                 WS-FUNC-DATE(9:2) ":" WS-FUNC-DATE(11:2)
                 DELIMITED BY SIZE INTO WS-OIA-CLOCK.

       RENDER-OIA.
          MOVE WS-CLR-BASE TO WS-PUT-COLOR
          MOVE 24 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
          MOVE LBL-OIA-SYS TO WS-PUT-TEXT  PERFORM ANSI-PUT
          IF WS-ERR-MSG NOT = SPACES
              MOVE "1;31" TO WS-PUT-COLOR
              MOVE 24 TO WS-AT-ROW  MOVE 14 TO WS-AT-COL
              MOVE WS-ERR-MSG TO WS-PUT-TEXT  PERFORM ANSI-PUT
          ELSE
              MOVE WS-CLR-HI TO WS-PUT-COLOR
              MOVE 24 TO WS-AT-ROW  MOVE 14 TO WS-AT-COL
              MOVE LBL-OIA-READY TO WS-PUT-TEXT  PERFORM ANSI-PUT
          END-IF
          PERFORM BUILD-OIA-CLOCK
          MOVE WS-CLR-BASE TO WS-PUT-COLOR
          MOVE 24 TO WS-AT-ROW  MOVE 63 TO WS-AT-COL
          MOVE WS-OIA-CLOCK TO WS-PUT-TEXT  PERFORM ANSI-PUT.

       INQ-READ-CMD.
          PERFORM PG-COMMIT
          MOVE 22 TO WS-AT-ROW  MOVE 22 TO WS-AT-COL
          PERFORM ANSI-CURSOR-AT
          PERFORM ANSI-SHOW-CURSOR
          MOVE SPACES TO WS-CMD-LINE
          ACCEPT WS-CMD-LINE
          INSPECT WS-CMD-LINE REPLACING ALL X"0D" BY SPACE
          INSPECT WS-CMD-LINE REPLACING ALL X"0A" BY SPACE
          INSPECT WS-CMD-LINE REPLACING ALL X"09" BY SPACE
          MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-CMD-LINE))
               TO WS-CMD-NORM
          IF SCREEN-ON
              PERFORM ANSI-HIDE-CURSOR
          END-IF.

       ACCT-TRAN.
           MOVE "PBNK-ACCT"   TO WS-SCR-PFX
           MOVE LBL-ACCTTITLE TO WS-SCR-TITLE
           MOVE LBL-PF-INQ    TO WS-SCR-PF
           MOVE SPACES        TO WS-ERR-MSG WS-STATUS-MSG
           IF WS-KEY = SPACES
               MOVE "0010010000001" TO WS-KEY
           END-IF
           PERFORM ACCT-QUERY
           PERFORM ACCT-RENDER
           IF SCREEN-ON
               PERFORM ACCT-EVENT-LOOP
           END-IF.

       ACCT-QUERY.
           MOVE "N" TO WS-NF-FLAG
           PERFORM NORMALIZE-KEY
           MOVE WS-KEY TO HV-ACCT
           PERFORM PG-COMMIT
           EXEC SQL
               SELECT a.acct_name, a.branch_code, a.product_code,
                      a.acct_status, a.cust_id,
                      COALESCE(TO_CHAR(a.opened_date,
                               'YYYY-MM-DD'),''),
                      COALESCE(TO_CHAR(a.dormancy_date,
                               'YYYY-MM-DD'),''),
                      COALESCE(b.balance_jpy,0),
                      COALESCE(b.available_jpy,0),
                      COALESCE(b.hold_jpy,0)
                 INTO :HV-ANAME, :HV-BRANCH, :HV-PROD,
                      :HV-ASTATUS, :HV-ACUST,
                      :HV-OPENED, :HV-DORM,
                      :HV-BAL, :HV-AVAIL, :HV-HOLD
                 FROM accounts a
                 LEFT JOIN balances b
                   ON b.account_number = a.acct_number
                WHERE a.acct_number = :HV-ACCT
           END-EXEC
           IF SQLCODE NOT = 0
               MOVE "Y" TO WS-NF-FLAG
               EXIT PARAGRAPH
           END-IF
           PERFORM PG-COMMIT
           EXEC SQL
               SELECT COUNT(*) INTO :HV-TXNCNT
                 FROM transactions
                WHERE account_number = :HV-ACCT
                   OR counter_account_number = :HV-ACCT
           END-EXEC
           MOVE HV-ANAME   TO WS-A-NAME
           MOVE HV-BRANCH  TO WS-A-BRANCH
           MOVE HV-PROD    TO WS-A-PROD
           MOVE HV-ASTATUS TO WS-A-STATUS
           MOVE HV-ACUST   TO WS-A-CUST
           MOVE HV-OPENED  TO WS-A-OPENED
           MOVE HV-DORM    TO WS-A-DORM
           MOVE HV-BAL     TO WS-A-BAL-E
           MOVE HV-AVAIL   TO WS-A-AVAIL-E
           MOVE HV-HOLD    TO WS-A-HOLD-E
           MOVE HV-TXNCNT  TO WS-A-TXNCNT-E.

       ACCT-RENDER.
           IF SCREEN-ON
               PERFORM RENDER-HDR-ANSI
               IF WS-NF-FLAG = "Y"
                   PERFORM RENDER-NOTFOUND-SCREEN
               ELSE
                   PERFORM ACCT-RENDER-SCREEN
               END-IF
               PERFORM RENDER-INQ-FOOT-ANSI
           ELSE
               PERFORM ACCT-RENDER-PLAIN
           END-IF.

       ACCT-RENDER-SCREEN.
           MOVE LBL-A-ANO TO WS-FLD-LBL
           MOVE WS-KEY TO WS-FLD-VAL
           MOVE 4 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-A-NAME TO WS-FLD-LBL
           MOVE WS-A-NAME TO WS-FLD-VAL
           MOVE 5 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-A-BRANCH TO WS-FLD-LBL
           MOVE WS-A-BRANCH TO WS-FLD-VAL
           MOVE 6 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-A-PROD TO WS-FLD-LBL
           MOVE WS-A-PROD TO WS-FLD-VAL
           MOVE 7 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-A-STATUS TO WS-FLD-LBL
           MOVE WS-A-STATUS TO WS-FLD-VAL
           MOVE 8 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-A-CUST TO WS-FLD-LBL
           MOVE WS-A-CUST TO WS-FLD-VAL
           MOVE 9 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-A-OPENED TO WS-FLD-LBL
           MOVE WS-A-OPENED TO WS-FLD-VAL
           MOVE 10 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-A-DORM TO WS-FLD-LBL
           MOVE WS-A-DORM TO WS-FLD-VAL
           MOVE 11 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-A-BAL TO WS-FLD-LBL
           MOVE WS-A-BAL-E TO WS-FLD-VAL
           MOVE 13 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-A-AVAIL TO WS-FLD-LBL
           MOVE WS-A-AVAIL-E TO WS-FLD-VAL
           MOVE 14 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-A-HOLD TO WS-FLD-LBL
           MOVE WS-A-HOLD-E TO WS-FLD-VAL
           MOVE 15 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-A-TXNCNT TO WS-FLD-LBL
           MOVE WS-A-TXNCNT-E TO WS-FLD-VAL
           MOVE 16 TO WS-FLD-LINE
           PERFORM RENDER-FIELD.

       ACCT-RENDER-PLAIN.
           IF WS-NF-FLAG = "Y"
               DISPLAY FUNCTION TRIM(LBL-NOTFOUND)
               EXIT PARAGRAPH
           END-IF
           DISPLAY " "
           DISPLAY "== " FUNCTION TRIM(LBL-ACCTTITLE)
           DISPLAY FUNCTION TRIM(LBL-A-ANO) " "
                   FUNCTION TRIM(WS-KEY)
           DISPLAY FUNCTION TRIM(LBL-A-NAME) " "
                   FUNCTION TRIM(WS-A-NAME)
           DISPLAY FUNCTION TRIM(LBL-A-BRANCH) " " WS-A-BRANCH
                   "  " FUNCTION TRIM(LBL-A-PROD) " " WS-A-PROD
           DISPLAY FUNCTION TRIM(LBL-A-STATUS) " " WS-A-STATUS
                   "  " FUNCTION TRIM(LBL-A-CUST) " " WS-A-CUST
           DISPLAY FUNCTION TRIM(LBL-A-OPENED) " " WS-A-OPENED
                   "  " FUNCTION TRIM(LBL-A-DORM) " " WS-A-DORM
           DISPLAY FUNCTION TRIM(LBL-A-BAL) " "
                   FUNCTION TRIM(WS-A-BAL-E)
           DISPLAY FUNCTION TRIM(LBL-A-AVAIL) " "
                   FUNCTION TRIM(WS-A-AVAIL-E)
           DISPLAY FUNCTION TRIM(LBL-A-HOLD) " "
                   FUNCTION TRIM(WS-A-HOLD-E)
           DISPLAY FUNCTION TRIM(LBL-A-TXNCNT) " "
                   FUNCTION TRIM(WS-A-TXNCNT-E).

       ACCT-EVENT-LOOP.
           MOVE "N" TO WS-EXIT-FLAG
           PERFORM UNTIL WS-EXIT-FLAG = "Y"
               PERFORM INQ-READ-CMD
               EVALUATE WS-CMD-NORM
                   WHEN SPACES
                   WHEN "B"
                   WHEN "BACK"
                   WHEN "MENU"
                   WHEN "EXIT"
                   WHEN "QUIT"
                       MOVE "Y" TO WS-EXIT-FLAG
                   WHEN OTHER
                       MOVE FUNCTION TRIM(WS-CMD-LINE) TO WS-KEY
                       PERFORM ACCT-QUERY
                       PERFORM ACCT-RENDER
               END-EVALUATE
           END-PERFORM.

       CUST-TRAN.
           MOVE "PBNK-CUST"   TO WS-SCR-PFX
           MOVE LBL-CUSTTITLE TO WS-SCR-TITLE
           MOVE LBL-PF-INQ    TO WS-SCR-PF
           MOVE SPACES        TO WS-ERR-MSG WS-STATUS-MSG
           IF WS-KEY = SPACES
               MOVE "0000000001" TO WS-KEY
           END-IF
           PERFORM CUST-QUERY
           PERFORM CUST-RENDER
           IF SCREEN-ON
               PERFORM CUST-EVENT-LOOP
           END-IF.

       CUST-QUERY.
           MOVE "N" TO WS-NF-FLAG
           PERFORM NORMALIZE-KEY
           MOVE WS-KEY(1:10) TO HV-CUST
           PERFORM PG-COMMIT
           EXEC SQL
               SELECT cust_name, cust_name_kana, cust_status,
                      tier, COALESCE(phone,''),
                      COALESCE(address,'')
                 INTO :HV-CNAME, :HV-CKANA, :HV-CSTATUS,
                      :HV-CTIER, :HV-CPHONE, :HV-CADDR
                 FROM customers
                WHERE cust_id = :HV-CUST
           END-EXEC
           IF SQLCODE NOT = 0
               MOVE "Y" TO WS-NF-FLAG
               EXIT PARAGRAPH
           END-IF
           MOVE HV-CNAME   TO WS-C-NAME
           MOVE HV-CKANA   TO WS-C-KANA
           MOVE HV-CSTATUS TO WS-C-STATUS
           MOVE HV-CTIER   TO WS-C-TIER
           MOVE HV-CPHONE  TO WS-C-PHONE
           MOVE HV-CADDR   TO WS-C-ADDR
           PERFORM CUST-LOAD-ACCTS.

       CUST-LOAD-ACCTS.
           MOVE 0 TO WS-C-ACNT
           MOVE 0 TO WS-C-TOTAL-RAW
           PERFORM CLEAR-CAROWS
           MOVE 0 TO WS-ROW-IDX
           PERFORM PG-COMMIT
           EXEC SQL
               DECLARE CCUR CURSOR FOR
               SELECT a.acct_number, a.product_code,
                      a.acct_status, COALESCE(b.balance_jpy,0)
                 FROM accounts a
                 LEFT JOIN balances b
                   ON b.account_number = a.acct_number
                WHERE a.cust_id = :HV-CUST
                ORDER BY a.acct_number
                LIMIT 12
           END-EXEC
           EXEC SQL OPEN CCUR END-EXEC
           PERFORM UNTIL SQLCODE NOT = 0
               EXEC SQL
                   FETCH CCUR INTO :HV-ACCT, :HV-PROD,
                                   :HV-ASTATUS, :HV-BAL
               END-EXEC
               IF SQLCODE = 0
                   ADD 1 TO WS-ROW-IDX
                   MOVE HV-ACCT     TO CA-ANO(WS-ROW-IDX)
                   MOVE HV-PROD     TO CA-PROD(WS-ROW-IDX)
                   MOVE HV-ASTATUS  TO CA-STATUS(WS-ROW-IDX)
                   MOVE HV-BAL      TO WS-AMT-EDIT
                   MOVE WS-AMT-EDIT TO CA-BAL(WS-ROW-IDX)
                   ADD HV-BAL TO WS-C-TOTAL-RAW
               END-IF
           END-PERFORM
           EXEC SQL CLOSE CCUR END-EXEC
           MOVE WS-ROW-IDX TO WS-C-ACNT
           MOVE WS-C-TOTAL-RAW TO WS-C-TOTAL-E.

       CLEAR-CAROWS.
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > 12
               MOVE SPACES TO CA-ANO(WS-ROW-IDX)
                              CA-PROD(WS-ROW-IDX)
                              CA-STATUS(WS-ROW-IDX)
                              CA-BAL(WS-ROW-IDX)
           END-PERFORM.

       CUST-RENDER.
           IF SCREEN-ON
               PERFORM RENDER-HDR-ANSI
               IF WS-NF-FLAG = "Y"
                   PERFORM RENDER-NOTFOUND-SCREEN
               ELSE
                   PERFORM CUST-RENDER-SCREEN
               END-IF
               PERFORM RENDER-INQ-FOOT-ANSI
           ELSE
               PERFORM CUST-RENDER-PLAIN
           END-IF.

       CUST-RENDER-SCREEN.
           MOVE LBL-A-CUST TO WS-FLD-LBL
           MOVE WS-KEY TO WS-FLD-VAL
           MOVE 4 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-C-NAME TO WS-FLD-LBL
           MOVE WS-C-NAME TO WS-FLD-VAL
           MOVE 5 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-C-KANA TO WS-FLD-LBL
           MOVE WS-C-KANA TO WS-FLD-VAL
           MOVE 6 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-C-STATUS TO WS-FLD-LBL
           MOVE WS-C-STATUS TO WS-FLD-VAL
           MOVE 7 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-C-TIER TO WS-FLD-LBL
           MOVE WS-C-TIER TO WS-FLD-VAL
           MOVE 8 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-C-PHONE TO WS-FLD-LBL
           MOVE WS-C-PHONE TO WS-FLD-VAL
           MOVE 9 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE LBL-C-ADDR TO WS-FLD-LBL
           MOVE WS-C-ADDR TO WS-FLD-VAL
           MOVE 10 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE WS-CLR-HI TO WS-PUT-COLOR
           MOVE 12 TO WS-FLD-LINE  MOVE 4 TO WS-FLD-COL
           MOVE LBL-C-ACCTS TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE WS-CLR-BASE TO WS-PUT-COLOR
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > WS-C-ACNT
               COMPUTE WS-FLD-LINE = 12 + WS-ROW-IDX
               MOVE 6 TO WS-FLD-COL
               MOVE CA-ANO(WS-ROW-IDX) TO WS-FLD-VAL
               PERFORM RENDER-AT
               MOVE 22 TO WS-FLD-COL
               MOVE CA-PROD(WS-ROW-IDX) TO WS-FLD-VAL
               PERFORM RENDER-AT
               MOVE 28 TO WS-FLD-COL
               MOVE CA-STATUS(WS-ROW-IDX) TO WS-FLD-VAL
               PERFORM RENDER-AT
               MOVE 34 TO WS-FLD-COL
               MOVE CA-BAL(WS-ROW-IDX) TO WS-FLD-VAL
               PERFORM RENDER-AT
           END-PERFORM
           MOVE LBL-C-TOTAL TO WS-FLD-LBL
           MOVE WS-C-TOTAL-E TO WS-FLD-VAL
           MOVE 20 TO WS-FLD-LINE
           PERFORM RENDER-FIELD.

       CUST-RENDER-PLAIN.
           IF WS-NF-FLAG = "Y"
               DISPLAY FUNCTION TRIM(LBL-NOTFOUND)
               EXIT PARAGRAPH
           END-IF
           DISPLAY " "
           DISPLAY "== " FUNCTION TRIM(LBL-CUSTTITLE)
           DISPLAY FUNCTION TRIM(LBL-A-CUST) " "
                   FUNCTION TRIM(WS-KEY)
           DISPLAY FUNCTION TRIM(LBL-C-NAME) " "
                   FUNCTION TRIM(WS-C-NAME)
           DISPLAY FUNCTION TRIM(LBL-C-KANA) " "
                   FUNCTION TRIM(WS-C-KANA)
           DISPLAY FUNCTION TRIM(LBL-C-STATUS) " " WS-C-STATUS
                   "  " FUNCTION TRIM(LBL-C-TIER) " " WS-C-TIER
           DISPLAY FUNCTION TRIM(LBL-C-PHONE) " "
                   FUNCTION TRIM(WS-C-PHONE)
           DISPLAY FUNCTION TRIM(LBL-C-ADDR) " "
                   FUNCTION TRIM(WS-C-ADDR)
           DISPLAY FUNCTION TRIM(LBL-C-ACCTS) ":"
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > WS-C-ACNT
               DISPLAY "  " CA-ANO(WS-ROW-IDX) " "
                       CA-PROD(WS-ROW-IDX) " "
                       CA-STATUS(WS-ROW-IDX) " "
                       FUNCTION TRIM(CA-BAL(WS-ROW-IDX))
           END-PERFORM
           DISPLAY FUNCTION TRIM(LBL-C-TOTAL) " "
                   FUNCTION TRIM(WS-C-TOTAL-E).

       CUST-EVENT-LOOP.
           MOVE "N" TO WS-EXIT-FLAG
           PERFORM UNTIL WS-EXIT-FLAG = "Y"
               PERFORM INQ-READ-CMD
               EVALUATE WS-CMD-NORM
                   WHEN SPACES
                   WHEN "B"
                   WHEN "BACK"
                   WHEN "MENU"
                   WHEN "EXIT"
                   WHEN "QUIT"
                       MOVE "Y" TO WS-EXIT-FLAG
                   WHEN OTHER
                       MOVE FUNCTION TRIM(WS-CMD-LINE) TO WS-KEY
                       PERFORM CUST-QUERY
                       PERFORM CUST-RENDER
               END-EVALUATE
           END-PERFORM.

       HIST-TRAN.
           MOVE "PBNK-HIST"   TO WS-SCR-PFX
           MOVE LBL-HISTTITLE TO WS-SCR-TITLE
           MOVE LBL-PF-PAGE   TO WS-SCR-PF
           MOVE SPACES        TO WS-ERR-MSG
           IF WS-KEY = SPACES
               MOVE "0010010000001" TO WS-KEY
           END-IF
           MOVE 1 TO WS-PAGE
           PERFORM HIST-COUNT
           PERFORM HIST-LOAD-PAGE
           PERFORM HIST-RENDER
           IF SCREEN-ON
               PERFORM HIST-EVENT-LOOP
           END-IF.

       HIST-COUNT.
           MOVE "N" TO WS-NF-FLAG
           PERFORM NORMALIZE-KEY
           MOVE WS-KEY TO HV-ACCT
           MOVE 0 TO WS-JTOTAL
           PERFORM PG-COMMIT
           EXEC SQL
               SELECT COUNT(*) INTO :HV-CNT
                 FROM postings
                WHERE account_number = :HV-ACCT
           END-EXEC
           MOVE HV-CNT TO WS-JTOTAL
           PERFORM PG-COMMIT
           EXEC SQL
               SELECT COALESCE(balance_jpy,0) INTO :HV-BAL
                 FROM balances
                WHERE account_number = :HV-ACCT
           END-EXEC
           IF SQLCODE = 0
               MOVE HV-BAL TO WS-H-BAL-E
           ELSE
               MOVE 0 TO WS-H-BAL-E
           END-IF
           IF WS-JTOTAL = 0
               MOVE "Y" TO WS-NF-FLAG
           END-IF.

       HIST-LOAD-PAGE.
           COMPUTE WS-OFFSET = (WS-PAGE - 1) * WS-PAGE-SIZE
           MOVE WS-OFFSET    TO HV-OFFSET
           MOVE WS-PAGE-SIZE TO HV-LIMIT
           PERFORM CLEAR-HROWS
           MOVE 0 TO WS-ROW-IDX
           PERFORM PG-COMMIT
           EXEC SQL
               DECLARE HCUR CURSOR FOR
               SELECT TO_CHAR(business_date,'YYYY-MM-DD'),
                      txn_id, posting_role,
                      COALESCE(debit_jpy,0),
                      COALESCE(credit_jpy,0)
                 FROM postings
                WHERE account_number = :HV-ACCT
                ORDER BY business_date, txn_id, line_no
                OFFSET :HV-OFFSET LIMIT :HV-LIMIT
           END-EXEC
           EXEC SQL OPEN HCUR END-EXEC
           PERFORM UNTIL SQLCODE NOT = 0
               EXEC SQL
                   FETCH HCUR INTO :HV-DATEKEY, :HV-TXN,
                                   :HV-ROLE, :HV-DR, :HV-CR
               END-EXEC
               IF SQLCODE = 0
                   ADD 1 TO WS-ROW-IDX
                   MOVE HV-DATEKEY TO HR-DATE(WS-ROW-IDX)
                   MOVE HV-TXN     TO HR-TXN(WS-ROW-IDX)
                   MOVE HV-ROLE    TO HR-ROLE(WS-ROW-IDX)
                   ADD HV-DR HV-CR GIVING WS-AMT-EDIT
                   MOVE WS-AMT-EDIT TO HR-AMT(WS-ROW-IDX)
               END-IF
           END-PERFORM
           EXEC SQL CLOSE HCUR END-EXEC.

       CLEAR-HROWS.
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > 10
               MOVE SPACES TO HR-DATE(WS-ROW-IDX)
                              HR-TXN(WS-ROW-IDX)
                              HR-ROLE(WS-ROW-IDX)
                              HR-AMT(WS-ROW-IDX)
           END-PERFORM.

       HIST-RENDER.
           MOVE SPACES TO WS-STATUS-MSG
           STRING FUNCTION TRIM(LBL-PAGEOF) " " WS-PAGE
                  DELIMITED BY SIZE INTO WS-STATUS-MSG
           IF SCREEN-ON
               PERFORM RENDER-HDR-ANSI
               IF WS-NF-FLAG = "Y"
                   PERFORM RENDER-NOTFOUND-SCREEN
               ELSE
                   PERFORM HIST-RENDER-SCREEN
               END-IF
               PERFORM RENDER-INQ-FOOT-ANSI
           ELSE
               PERFORM HIST-RENDER-PLAIN
           END-IF.

       HIST-RENDER-SCREEN.
           MOVE LBL-A-ANO TO WS-FLD-LBL
           MOVE WS-KEY TO WS-FLD-VAL
           MOVE 3 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE WS-CLR-BASE TO WS-PUT-COLOR
           MOVE 3 TO WS-FLD-LINE  MOVE 44 TO WS-FLD-COL
           MOVE LBL-H-BAL TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 3 TO WS-FLD-LINE  MOVE 62 TO WS-FLD-COL
           MOVE WS-H-BAL-E TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 2 TO WS-FLD-COL
           MOVE LBL-H-DATE TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 16 TO WS-FLD-COL
           MOVE LBL-H-TXN TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 38 TO WS-FLD-COL
           MOVE LBL-H-ROLE TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 50 TO WS-FLD-COL
           MOVE LBL-H-AMT TO WS-FLD-VAL  PERFORM RENDER-AT
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > 10
               IF HR-TXN(WS-ROW-IDX) NOT = SPACES
                   COMPUTE WS-FLD-LINE = 6 + WS-ROW-IDX
                   MOVE 2 TO WS-FLD-COL
                   MOVE HR-DATE(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 16 TO WS-FLD-COL
                   MOVE HR-TXN(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 38 TO WS-FLD-COL
                   MOVE HR-ROLE(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 50 TO WS-FLD-COL
                   MOVE HR-AMT(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
               END-IF
           END-PERFORM.

       HIST-RENDER-PLAIN.
           IF WS-NF-FLAG = "Y"
               DISPLAY FUNCTION TRIM(LBL-NOTFOUND)
               EXIT PARAGRAPH
           END-IF
           DISPLAY " "
           DISPLAY "== " FUNCTION TRIM(LBL-HISTTITLE)
                   " (" FUNCTION TRIM(LBL-PAGEOF) " " WS-PAGE ")"
           DISPLAY FUNCTION TRIM(LBL-A-ANO) " "
                   FUNCTION TRIM(WS-KEY) "  "
                   FUNCTION TRIM(LBL-H-BAL) " "
                   FUNCTION TRIM(WS-H-BAL-E)
                   "  total " WS-JTOTAL
           DISPLAY LBL-H-DATE " " LBL-H-TXN " "
                   LBL-H-ROLE " " LBL-H-AMT
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > 10
               IF HR-TXN(WS-ROW-IDX) NOT = SPACES
                   DISPLAY HR-DATE(WS-ROW-IDX) " "
                           HR-TXN(WS-ROW-IDX) " "
                           HR-ROLE(WS-ROW-IDX) " "
                           FUNCTION TRIM(HR-AMT(WS-ROW-IDX))
               END-IF
           END-PERFORM.

       HIST-EVENT-LOOP.
           MOVE "N" TO WS-EXIT-FLAG
           PERFORM UNTIL WS-EXIT-FLAG = "Y"
               PERFORM INQ-READ-CMD
               EVALUATE WS-CMD-NORM
                   WHEN SPACES
                   WHEN "B"
                   WHEN "BACK"
                   WHEN "MENU"
                   WHEN "EXIT"
                   WHEN "QUIT"
                       MOVE "Y" TO WS-EXIT-FLAG
                   WHEN "N"
                   WHEN "NEXT"
                       IF (WS-PAGE * WS-PAGE-SIZE) < WS-JTOTAL
                           ADD 1 TO WS-PAGE
                           PERFORM HIST-LOAD-PAGE
                           PERFORM HIST-RENDER
                       END-IF
                   WHEN "P"
                   WHEN "PREV"
                       IF WS-PAGE > 1
                           SUBTRACT 1 FROM WS-PAGE
                           PERFORM HIST-LOAD-PAGE
                           PERFORM HIST-RENDER
                       END-IF
                   WHEN OTHER
                       PERFORM REVS-PARSE-ROW
                       IF WS-ROW-OK = "Y" AND
                          HR-TXN(WS-ROW-PICK) IS NUMERIC
                           MOVE HR-TXN(WS-ROW-PICK) TO WS-PREFILL-TXN
                           MOVE "REVS" TO WS-PENDING-TRAN
                           MOVE "Y" TO WS-EXIT-FLAG
                       ELSE
                           MOVE FUNCTION TRIM(WS-CMD-LINE) TO WS-KEY
                           MOVE 1 TO WS-PAGE
                           PERFORM HIST-COUNT
                           PERFORM HIST-LOAD-PAGE
                           PERFORM HIST-RENDER
                       END-IF
               END-EVALUATE
           END-PERFORM.

       AUDT-TRAN.
           MOVE "PBNK-AUDT"   TO WS-SCR-PFX
           MOVE LBL-AUDTTITLE TO WS-SCR-TITLE
           MOVE LBL-PF-PAGE   TO WS-SCR-PF
           MOVE SPACES        TO WS-ERR-MSG
           IF WS-KEY = SPACES
               MOVE WS-DEMO-BDATE-PG TO WS-KEY
           END-IF
           MOVE 1 TO WS-PAGE
           PERFORM AUDT-COUNT
           PERFORM AUDT-LOAD-PAGE
           PERFORM AUDT-RENDER
           IF SCREEN-ON
               PERFORM AUDT-EVENT-LOOP
           END-IF.

       VALIDATE-DATE.
           MOVE "Y" TO WS-DATE-OK
           IF WS-DATEKEY(5:1) NOT = "-"
              OR WS-DATEKEY(8:1) NOT = "-"
               MOVE "N" TO WS-DATE-OK
           END-IF
           IF WS-DATEKEY(1:4) IS NOT NUMERIC
              OR WS-DATEKEY(6:2) IS NOT NUMERIC
              OR WS-DATEKEY(9:2) IS NOT NUMERIC
               MOVE "N" TO WS-DATE-OK
           END-IF.

       AUDT-COUNT.
           MOVE "N" TO WS-NF-FLAG
           PERFORM NORMALIZE-KEY
           MOVE WS-KEY(1:10) TO WS-DATEKEY
           PERFORM VALIDATE-DATE
           IF WS-DATE-OK = "N"
               MOVE "Y" TO WS-NF-FLAG
               MOVE 0 TO WS-JTOTAL
               EXIT PARAGRAPH
           END-IF
           MOVE WS-DATEKEY TO HV-BDATE
           MOVE 0 TO WS-JTOTAL
           PERFORM PG-COMMIT
           EXEC SQL
               SELECT COUNT(*) INTO :HV-CNT
                 FROM audit_log
                WHERE business_date = CAST(:HV-BDATE AS DATE)
           END-EXEC
           IF SQLCODE NOT = 0
               MOVE "Y" TO WS-NF-FLAG
               EXIT PARAGRAPH
           END-IF
           MOVE HV-CNT TO WS-JTOTAL
           IF WS-JTOTAL = 0
               MOVE "Y" TO WS-NF-FLAG
           END-IF.

       AUDT-LOAD-PAGE.
           COMPUTE WS-OFFSET = (WS-PAGE - 1) * WS-PAGE-SIZE
           MOVE WS-OFFSET    TO HV-OFFSET
           MOVE WS-PAGE-SIZE TO HV-LIMIT
           PERFORM CLEAR-AROWS
           MOVE 0 TO WS-ROW-IDX
           PERFORM PG-COMMIT
           EXEC SQL
               DECLARE ACUR CURSOR FOR
               SELECT system_ts,
                      subsystem, action, severity,
                      COALESCE(target_id,'')
                 FROM audit_log
                WHERE business_date = CAST(:HV-BDATE AS DATE)
                ORDER BY audit_id DESC
                OFFSET :HV-OFFSET LIMIT :HV-LIMIT
           END-EXEC
           EXEC SQL OPEN ACUR END-EXEC
           PERFORM UNTIL SQLCODE NOT = 0
               EXEC SQL
                   FETCH ACUR INTO :HV-TS, :HV-SS,
                                   :HV-ACTION, :HV-SEV, :HV-TGT
               END-EXEC
               IF SQLCODE = 0
                   ADD 1 TO WS-ROW-IDX
                   MOVE HV-TS     TO AU-TS(WS-ROW-IDX)
                   MOVE HV-SS     TO AU-SS(WS-ROW-IDX)
                   MOVE HV-ACTION TO AU-ACT(WS-ROW-IDX)
                   MOVE HV-SEV    TO AU-SEV(WS-ROW-IDX)
                   MOVE HV-TGT    TO AU-TGT(WS-ROW-IDX)
               END-IF
           END-PERFORM
           EXEC SQL CLOSE ACUR END-EXEC.

       CLEAR-AROWS.
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > 10
               MOVE SPACES TO AU-TS(WS-ROW-IDX)
                              AU-SS(WS-ROW-IDX)
                              AU-ACT(WS-ROW-IDX)
                              AU-SEV(WS-ROW-IDX)
                              AU-TGT(WS-ROW-IDX)
           END-PERFORM.

       AUDT-RENDER.
           MOVE SPACES TO WS-STATUS-MSG
           STRING FUNCTION TRIM(LBL-PAGEOF) " " WS-PAGE
                  DELIMITED BY SIZE INTO WS-STATUS-MSG
           IF SCREEN-ON
               PERFORM RENDER-HDR-ANSI
               IF WS-NF-FLAG = "Y"
                   PERFORM RENDER-NOTFOUND-SCREEN
               ELSE
                   PERFORM AUDT-RENDER-SCREEN
               END-IF
               PERFORM RENDER-INQ-FOOT-ANSI
           ELSE
               PERFORM AUDT-RENDER-PLAIN
           END-IF.

       AUDT-RENDER-SCREEN.
           MOVE LBL-H-DATE TO WS-FLD-LBL
           MOVE WS-KEY TO WS-FLD-VAL
           MOVE 3 TO WS-FLD-LINE
           PERFORM RENDER-FIELD
           MOVE WS-CLR-BASE TO WS-PUT-COLOR
           MOVE 5 TO WS-FLD-LINE  MOVE 2 TO WS-FLD-COL
           MOVE LBL-AU-TS TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 22 TO WS-FLD-COL
           MOVE LBL-AU-SS TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 40 TO WS-FLD-COL
           MOVE LBL-AU-ACT TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 66 TO WS-FLD-COL
           MOVE LBL-AU-SEV TO WS-FLD-VAL  PERFORM RENDER-AT
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > 10
               IF AU-TS(WS-ROW-IDX) NOT = SPACES
                   COMPUTE WS-FLD-LINE = 6 + WS-ROW-IDX
                   PERFORM SET-SEV-COLOR
                   MOVE 2 TO WS-FLD-COL
                   MOVE AU-TS(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 22 TO WS-FLD-COL
                   MOVE AU-SS(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 40 TO WS-FLD-COL
                   MOVE AU-ACT(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 66 TO WS-FLD-COL
                   MOVE AU-SEV(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
               END-IF
           END-PERFORM.

       SET-SEV-COLOR.
           EVALUATE AU-SEV(WS-ROW-IDX)
               WHEN "I" MOVE "32"      TO WS-PUT-COLOR
               WHEN "W" MOVE "1;33"    TO WS-PUT-COLOR
               WHEN "E" MOVE "1;31"    TO WS-PUT-COLOR
               WHEN "C" MOVE "1;37;41" TO WS-PUT-COLOR
               WHEN OTHER MOVE "32"    TO WS-PUT-COLOR
           END-EVALUATE.

       AUDT-RENDER-PLAIN.
           IF WS-NF-FLAG = "Y"
               DISPLAY FUNCTION TRIM(LBL-NOTFOUND)
               EXIT PARAGRAPH
           END-IF
           DISPLAY " "
           DISPLAY "== " FUNCTION TRIM(LBL-AUDTTITLE)
                   " (" FUNCTION TRIM(LBL-PAGEOF) " " WS-PAGE ")"
           DISPLAY FUNCTION TRIM(LBL-H-DATE) " "
                   FUNCTION TRIM(WS-KEY)
                   "  total " WS-JTOTAL
           DISPLAY LBL-AU-TS " " LBL-AU-SS " "
                   LBL-AU-ACT " " LBL-AU-SEV
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > 10
               IF AU-TS(WS-ROW-IDX) NOT = SPACES
                   DISPLAY AU-TS(WS-ROW-IDX) " "
                           FUNCTION TRIM(AU-SS(WS-ROW-IDX)) " "
                           FUNCTION TRIM(AU-ACT(WS-ROW-IDX)) " "
                           AU-SEV(WS-ROW-IDX) " "
                           FUNCTION TRIM(AU-TGT(WS-ROW-IDX))
               END-IF
           END-PERFORM.

       AUDT-EVENT-LOOP.
           MOVE "N" TO WS-EXIT-FLAG
           PERFORM UNTIL WS-EXIT-FLAG = "Y"
               PERFORM INQ-READ-CMD
               EVALUATE WS-CMD-NORM
                   WHEN SPACES
                   WHEN "B"
                   WHEN "BACK"
                   WHEN "MENU"
                   WHEN "EXIT"
                   WHEN "QUIT"
                       MOVE "Y" TO WS-EXIT-FLAG
                   WHEN "N"
                   WHEN "NEXT"
                       IF (WS-PAGE * WS-PAGE-SIZE) < WS-JTOTAL
                           ADD 1 TO WS-PAGE
                           PERFORM AUDT-LOAD-PAGE
                           PERFORM AUDT-RENDER
                       END-IF
                   WHEN "P"
                   WHEN "PREV"
                       IF WS-PAGE > 1
                           SUBTRACT 1 FROM WS-PAGE
                           PERFORM AUDT-LOAD-PAGE
                           PERFORM AUDT-RENDER
                       END-IF
                   WHEN OTHER
                       MOVE FUNCTION TRIM(WS-CMD-LINE) TO WS-KEY
                       MOVE 1 TO WS-PAGE
                       PERFORM AUDT-COUNT
                       PERFORM AUDT-LOAD-PAGE
                       PERFORM AUDT-RENDER
               END-EVALUATE
           END-PERFORM.

       BRUN-TRAN.
           MOVE "PBNK-BRUN"   TO WS-SCR-PFX
           MOVE LBL-BRUNTITLE TO WS-SCR-TITLE
           MOVE LBL-PF-BRUN   TO WS-SCR-PF
           MOVE SPACES        TO WS-ERR-MSG
           MOVE 1 TO WS-PAGE
           PERFORM BRUN-COUNT
           PERFORM BRUN-LOAD-PAGE
           PERFORM BRUN-RENDER
           IF SCREEN-ON
               PERFORM BRUN-EVENT-LOOP
           END-IF.

       BRUN-COUNT.
           MOVE "N" TO WS-NF-FLAG
           MOVE 0 TO WS-JTOTAL
           PERFORM PG-COMMIT
           EXEC SQL
               SELECT COUNT(*) INTO :HV-CNT FROM batch_run
           END-EXEC
           IF SQLCODE NOT = 0
               MOVE "Y" TO WS-NF-FLAG
               EXIT PARAGRAPH
           END-IF
           MOVE HV-CNT TO WS-JTOTAL
           IF WS-JTOTAL = 0
               MOVE "Y" TO WS-NF-FLAG
           END-IF.

       BRUN-LOAD-PAGE.
           COMPUTE WS-OFFSET = (WS-PAGE - 1) * WS-PAGE-SIZE
           MOVE WS-OFFSET    TO HV-OFFSET
           MOVE WS-PAGE-SIZE TO HV-LIMIT
           PERFORM CLEAR-BRROWS
           MOVE 0 TO WS-ROW-IDX
           PERFORM PG-COMMIT
           EXEC SQL
               DECLARE BCUR CURSOR FOR
               SELECT batch_id,
                      business_date,
                      status,
                      COALESCE(current_step,''),
                      COALESCE(txns_posted,0),
                      errors_count,
                      started_ts
                 FROM batch_run
                ORDER BY started_ts DESC
                OFFSET :HV-OFFSET LIMIT :HV-LIMIT
           END-EXEC
           EXEC SQL OPEN BCUR END-EXEC
           PERFORM UNTIL SQLCODE NOT = 0
               EXEC SQL
                   FETCH BCUR INTO :HV-BR-BID, :HV-BR-BD,
                                   :HV-BR-STATUS, :HV-BR-STEP,
                                   :HV-BR-TXNS, :HV-BR-ERRS,
                                   :HV-BR-START
               END-EXEC
               IF SQLCODE = 0
                   ADD 1 TO WS-ROW-IDX
                   MOVE HV-BR-BID    TO BR-BID(WS-ROW-IDX)
                   MOVE HV-BR-BD     TO BR-BD(WS-ROW-IDX)
                   MOVE HV-BR-STATUS TO BR-STATUS(WS-ROW-IDX)
                   MOVE HV-BR-STEP   TO BR-STEP(WS-ROW-IDX)
                   MOVE HV-BR-TXNS   TO WS-BR-NUM-EDIT
                   MOVE WS-BR-NUM-EDIT TO BR-TXNS(WS-ROW-IDX)
                   MOVE HV-BR-ERRS   TO WS-BR-NUM-EDIT
                   MOVE WS-BR-NUM-EDIT TO BR-ERRS(WS-ROW-IDX)
                   MOVE HV-BR-START  TO BR-START(WS-ROW-IDX)
               END-IF
           END-PERFORM
           EXEC SQL CLOSE BCUR END-EXEC.

       CLEAR-BRROWS.
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > 10
               MOVE SPACES TO BR-BID(WS-ROW-IDX)
                              BR-BD(WS-ROW-IDX)
                              BR-STATUS(WS-ROW-IDX)
                              BR-STEP(WS-ROW-IDX)
                              BR-TXNS(WS-ROW-IDX)
                              BR-ERRS(WS-ROW-IDX)
                              BR-START(WS-ROW-IDX)
           END-PERFORM.

       BRUN-RENDER.
           MOVE SPACES TO WS-STATUS-MSG
           STRING FUNCTION TRIM(LBL-PAGEOF) " " WS-PAGE
                  DELIMITED BY SIZE INTO WS-STATUS-MSG
           IF SCREEN-ON
               PERFORM RENDER-HDR-ANSI
               IF WS-NF-FLAG = "Y"
                   MOVE "1;33" TO WS-PUT-COLOR
                   MOVE 6 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
                   MOVE LBL-BR-EMPTY TO WS-PUT-TEXT  PERFORM ANSI-PUT
                   MOVE WS-CLR-BASE TO WS-PUT-COLOR
               ELSE
                   PERFORM BRUN-RENDER-SCREEN
               END-IF
               PERFORM RENDER-INQ-FOOT-ANSI
           ELSE
               PERFORM BRUN-RENDER-PLAIN
           END-IF.

       BRUN-RENDER-SCREEN.
           MOVE WS-CLR-BASE TO WS-PUT-COLOR
           MOVE 5 TO WS-FLD-LINE  MOVE 2 TO WS-FLD-COL
           MOVE LBL-BR-BID TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 17 TO WS-FLD-COL
           MOVE LBL-BR-BD TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 28 TO WS-FLD-COL
           MOVE LBL-BR-STATUS TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 32 TO WS-FLD-COL
           MOVE LBL-BR-STEP TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 48 TO WS-FLD-COL
           MOVE LBL-BR-TXNS TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 57 TO WS-FLD-COL
           MOVE LBL-BR-ERRS TO WS-FLD-VAL  PERFORM RENDER-AT
           MOVE 5 TO WS-FLD-LINE  MOVE 64 TO WS-FLD-COL
           MOVE LBL-BR-START TO WS-FLD-VAL  PERFORM RENDER-AT
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > 10
               IF BR-BID(WS-ROW-IDX) NOT = SPACES
                   COMPUTE WS-FLD-LINE = 6 + WS-ROW-IDX
                   PERFORM SET-STATUS-COLOR
                   MOVE 2 TO WS-FLD-COL
                   MOVE BR-BID(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 17 TO WS-FLD-COL
                   MOVE BR-BD(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 28 TO WS-FLD-COL
                   MOVE BR-STATUS(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 32 TO WS-FLD-COL
                   MOVE BR-STEP(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 48 TO WS-FLD-COL
                   MOVE BR-TXNS(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 57 TO WS-FLD-COL
                   MOVE BR-ERRS(WS-ROW-IDX) TO WS-FLD-VAL
                   PERFORM RENDER-AT
                   MOVE 64 TO WS-FLD-COL
                   MOVE BR-START(WS-ROW-IDX)(12:8) TO WS-FLD-VAL
                   PERFORM RENDER-AT
               END-IF
           END-PERFORM.

       SET-STATUS-COLOR.
           EVALUATE BR-STATUS(WS-ROW-IDX)
               WHEN "OK" MOVE "32"      TO WS-PUT-COLOR
               WHEN "RN" MOVE "1;33"    TO WS-PUT-COLOR
               WHEN "FL" MOVE "1;31"    TO WS-PUT-COLOR
               WHEN "AB" MOVE "1;37;41" TO WS-PUT-COLOR
               WHEN OTHER MOVE "32"     TO WS-PUT-COLOR
           END-EVALUATE.

       BRUN-RENDER-PLAIN.
           IF WS-NF-FLAG = "Y"
               DISPLAY FUNCTION TRIM(LBL-BR-EMPTY)
               EXIT PARAGRAPH
           END-IF
           DISPLAY " "
           DISPLAY "== " FUNCTION TRIM(LBL-BRUNTITLE)
                   " (" FUNCTION TRIM(LBL-PAGEOF) " " WS-PAGE ")"
           DISPLAY "total " WS-JTOTAL
           DISPLAY LBL-BR-BID " " LBL-BR-BD " " LBL-BR-STATUS " "
                   LBL-BR-STEP " " LBL-BR-TXNS " " LBL-BR-ERRS
           PERFORM VARYING WS-ROW-IDX FROM 1 BY 1
                   UNTIL WS-ROW-IDX > 10
               IF BR-BID(WS-ROW-IDX) NOT = SPACES
                   DISPLAY BR-BID(WS-ROW-IDX) " "
                           FUNCTION TRIM(BR-BD(WS-ROW-IDX)) " "
                           BR-STATUS(WS-ROW-IDX) " "
                           FUNCTION TRIM(BR-STEP(WS-ROW-IDX)) " "
                           FUNCTION TRIM(BR-TXNS(WS-ROW-IDX)) " "
                           FUNCTION TRIM(BR-ERRS(WS-ROW-IDX)) " "
                           FUNCTION TRIM(BR-START(WS-ROW-IDX))
               END-IF
           END-PERFORM.

       BRUN-EVENT-LOOP.
           MOVE "N" TO WS-EXIT-FLAG
           PERFORM UNTIL WS-EXIT-FLAG = "Y"
               PERFORM INQ-READ-CMD
               EVALUATE WS-CMD-NORM
                   WHEN SPACES
                   WHEN "B"
                   WHEN "BACK"
                   WHEN "MENU"
                   WHEN "EXIT"
                   WHEN "QUIT"
                       MOVE "Y" TO WS-EXIT-FLAG
                   WHEN "N"
                   WHEN "NEXT"
                       IF (WS-PAGE * WS-PAGE-SIZE) < WS-JTOTAL
                           ADD 1 TO WS-PAGE
                           PERFORM BRUN-LOAD-PAGE
                           PERFORM BRUN-RENDER
                       END-IF
                   WHEN "P"
                   WHEN "PREV"
                       IF WS-PAGE > 1
                           SUBTRACT 1 FROM WS-PAGE
                           PERFORM BRUN-LOAD-PAGE
                           PERFORM BRUN-RENDER
                       END-IF
                   WHEN "W"
                   WHEN "WATCH"
                       PERFORM BRUN-WATCH
                   WHEN OTHER
                       MOVE 1 TO WS-PAGE
                       PERFORM BRUN-COUNT
                       PERFORM BRUN-LOAD-PAGE
                       PERFORM BRUN-RENDER
               END-EVALUATE
           END-PERFORM.

        WATCH-SETUP.
           MOVE 12 TO WS-WATCH-CYCLES
           MOVE 2000 TO WS-WATCH-MS
           MOVE SPACES TO WS-WENV
           ACCEPT WS-WENV FROM ENVIRONMENT "CONSOLE_WATCH_CYCLES"
           IF WS-WENV NOT = SPACES
               COMPUTE WS-WATCH-CYCLES = FUNCTION NUMVAL(WS-WENV)
           END-IF
           MOVE SPACES TO WS-WENV
           ACCEPT WS-WENV FROM ENVIRONMENT "CONSOLE_WATCH_MS"
           IF WS-WENV NOT = SPACES
               COMPUTE WS-WATCH-MS = FUNCTION NUMVAL(WS-WENV)
           END-IF
           IF WS-WATCH-CYCLES < 1
               MOVE 1 TO WS-WATCH-CYCLES
           END-IF
           COMPUTE WS-WATCH-NANOS = WS-WATCH-MS * 1000000.

        BRUN-WATCH.
           PERFORM WATCH-SETUP
           PERFORM VARYING WS-WATCH-N FROM 1 BY 1
                   UNTIL WS-WATCH-N > WS-WATCH-CYCLES
               PERFORM BRUN-COUNT
               PERFORM BRUN-LOAD-PAGE
               PERFORM BRUN-RENDER
               IF SCREEN-ON
                   PERFORM RENDER-WATCH-IND
               END-IF
               IF WS-WATCH-NANOS > 0
                   CALL "CBL_OC_NANOSLEEP" USING WS-WATCH-NANOS
               END-IF
           END-PERFORM.

        RENDER-WATCH-IND.
           MOVE WS-WATCH-N TO WS-WN-DISP
           MOVE WS-WATCH-CYCLES TO WS-WC-DISP
           MOVE SPACES TO WS-PUT-TEXT
           STRING FUNCTION TRIM(LBL-WATCHING) " "
                  FUNCTION TRIM(WS-WN-DISP) "/"
                  FUNCTION TRIM(WS-WC-DISP)
                  DELIMITED BY SIZE INTO WS-PUT-TEXT
           MOVE WS-CLR-HI TO WS-PUT-COLOR
           MOVE 23 TO WS-AT-ROW  MOVE 48 TO WS-AT-COL
           PERFORM ANSI-PUT
           MOVE WS-CLR-BASE TO WS-PUT-COLOR.

       SCEN-TRAN.
           PERFORM SCEN-SETUP
           MOVE "PBNK-SCEN"   TO WS-SCR-PFX
           MOVE LBL-SCENTITLE TO WS-SCR-TITLE
           MOVE LBL-PF-SCEN   TO WS-SCR-PF
           MOVE SPACES        TO WS-ERR-MSG WS-STATUS-MSG
           MOVE "N" TO WS-SCEN-RAN
           IF NOT SCREEN-ON
               IF WS-SCEN-ARG NOT = SPACES
                   MOVE WS-SCEN-ARG TO WS-SCEN-VERB
                   PERFORM SCEN-RUN
               END-IF
               PERFORM SCEN-RENDER-PLAIN
               EXIT PARAGRAPH
           END-IF
           PERFORM SCEN-RENDER
           PERFORM SCEN-EVENT-LOOP.

       SCEN-SETUP.
           MOVE SPACES TO WS-SCEN-SCRIPT
           ACCEPT WS-SCEN-SCRIPT
               FROM ENVIRONMENT "CONSOLE_SCENARIO_SCRIPT"
           IF WS-SCEN-SCRIPT = SPACES
               MOVE "/workspace/console/scripts/run-scenario.sh"
                   TO WS-SCEN-SCRIPT
           END-IF.

       SCEN-EVENT-LOOP.
           MOVE "N" TO WS-EXIT-FLAG
           PERFORM UNTIL WS-EXIT-FLAG = "Y"
               PERFORM INQ-READ-CMD
               EVALUATE WS-CMD-NORM
                   WHEN SPACES
                   WHEN "B"
                   WHEN "BACK"
                   WHEN "MENU"
                   WHEN "EXIT"
                   WHEN "QUIT"
                       MOVE "Y" TO WS-EXIT-FLAG
                   WHEN "R"
                   WHEN "RECON"
                       MOVE "recon" TO WS-SCEN-VERB
                       PERFORM SCEN-RUN
                   WHEN "C"
                   WHEN "CONC"
                   WHEN "CONCURRENT"
                       MOVE "concurrent" TO WS-SCEN-VERB
                       PERFORM SCEN-RUN
                   WHEN "S"
                   WHEN "SMOKE"
                       MOVE "smoke" TO WS-SCEN-VERB
                       PERFORM SCEN-RUN
                   WHEN OTHER
                       CONTINUE
               END-EVALUATE
           END-PERFORM.

       SCEN-RUN.
           PERFORM PG-COMMIT
           IF SCREEN-ON
               PERFORM SCEN-RENDER-RUNNING
           END-IF
           MOVE SPACES TO WS-SCEN-RES-PATH WS-SCEN-KEY-PATH
           STRING FUNCTION TRIM(WS-SCEN-DIR) "/scenario-"
                  FUNCTION TRIM(WS-SCEN-VERB) ".result"
                  DELIMITED BY SIZE INTO WS-SCEN-RES-PATH
           STRING FUNCTION TRIM(WS-SCEN-DIR) "/scenario-"
                  FUNCTION TRIM(WS-SCEN-VERB) ".keys"
                  DELIMITED BY SIZE INTO WS-SCEN-KEY-PATH
           MOVE SPACES TO WS-CMD
           STRING "rm -f " FUNCTION TRIM(WS-SCEN-RES-PATH)
                  " " FUNCTION TRIM(WS-SCEN-KEY-PATH)
                  DELIMITED BY SIZE INTO WS-CMD
           CALL "SYSTEM" USING WS-CMD
           MOVE SPACES TO WS-CMD
           STRING "bash " FUNCTION TRIM(WS-SCEN-SCRIPT)
                  " " FUNCTION TRIM(WS-SCEN-VERB)
                  " " FUNCTION TRIM(WS-SCEN-DIR)
                  DELIMITED BY SIZE INTO WS-CMD
           CALL "SYSTEM" USING WS-CMD
           DIVIDE RETURN-CODE BY 256 GIVING WS-SCEN-RC
           PERFORM SCEN-READ-RESULT
           PERFORM SCEN-READ-KEYS
           MOVE "Y" TO WS-SCEN-RAN
           IF SCREEN-ON
               PERFORM SCEN-RENDER
           END-IF.

       SCEN-READ-RESULT.
           MOVE SPACES TO WS-SCEN-LINE WS-SCEN-RPASS WS-SCEN-RFAIL
                          WS-SCEN-RRC WS-SCEN-RELAPSED
           MOVE "N" TO WS-SCEN-OK-FLAG
           OPEN INPUT SCENRES-FILE
           IF WS-SCRES-FS NOT = "00"
               EXIT PARAGRAPH
           END-IF
           READ SCENRES-FILE
               AT END CONTINUE
               NOT AT END MOVE SCENRES-REC TO WS-SCEN-LINE
           END-READ
           CLOSE SCENRES-FILE
           PERFORM SCEN-PARSE-RESULT.

       SCEN-PARSE-RESULT.
           UNSTRING WS-SCEN-LINE DELIMITED BY "|"
               INTO WS-SCEN-TAG WS-SCEN-VERB WS-SCEN-RPASS
                    WS-SCEN-RFAIL WS-SCEN-RRC WS-SCEN-RELAPSED
           END-UNSTRING
           IF WS-SCEN-RC = 0
              AND FUNCTION TRIM(WS-SCEN-RFAIL) = "0"
              AND FUNCTION TRIM(WS-SCEN-RPASS) NOT = SPACES
               MOVE "Y" TO WS-SCEN-OK-FLAG
           ELSE
               MOVE "N" TO WS-SCEN-OK-FLAG
           END-IF.

       SCEN-READ-KEYS.
           MOVE 0 TO WS-SCEN-KCNT
           PERFORM VARYING WS-SCEN-FLD FROM 1 BY 1
                   UNTIL WS-SCEN-FLD > 8
               MOVE SPACES TO WS-SCEN-KEY(WS-SCEN-FLD)
           END-PERFORM
           OPEN INPUT SCENKEY-FILE
           IF WS-SCKEY-FS NOT = "00"
               EXIT PARAGRAPH
           END-IF
           MOVE "N" TO WS-SCEN-KEOF
           PERFORM UNTIL WS-SCEN-KEOF = "Y" OR WS-SCEN-KCNT >= 7
               READ SCENKEY-FILE
                   AT END MOVE "Y" TO WS-SCEN-KEOF
                   NOT AT END
                       ADD 1 TO WS-SCEN-KCNT
                       MOVE SCENKEY-REC
                           TO WS-SCEN-KEY(WS-SCEN-KCNT)
               END-READ
           END-PERFORM
           CLOSE SCENKEY-FILE.

       SCEN-RENDER.
           IF SCREEN-ON
               PERFORM RENDER-HDR-ANSI
               PERFORM SCEN-RENDER-LIST
               IF WS-SCEN-RAN = "Y"
                   PERFORM SCEN-RENDER-RESULT
               END-IF
               PERFORM RENDER-INQ-FOOT-ANSI
           ELSE
               PERFORM SCEN-RENDER-PLAIN
           END-IF.

       SCEN-RENDER-RUNNING.
           PERFORM RENDER-HDR-ANSI
           PERFORM SCEN-RENDER-LIST
           MOVE "1;33" TO WS-PUT-COLOR
           MOVE 11 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
           MOVE LBL-SC-RUNNING TO WS-PUT-TEXT  PERFORM ANSI-PUT
           MOVE WS-CLR-BASE TO WS-PUT-COLOR
           PERFORM RENDER-INQ-FOOT-ANSI.

       SCEN-RENDER-LIST.
           MOVE WS-CLR-BASE TO WS-PUT-COLOR
           MOVE 4 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
           MOVE LBL-SC-HDR TO WS-PUT-TEXT  PERFORM ANSI-PUT
           MOVE 6 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
           MOVE LBL-SC-DESC-RECON TO WS-PUT-TEXT  PERFORM ANSI-PUT
           MOVE 7 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
           MOVE LBL-SC-DESC-CONC TO WS-PUT-TEXT  PERFORM ANSI-PUT
           MOVE 8 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
           MOVE LBL-SC-DESC-SMOKE TO WS-PUT-TEXT  PERFORM ANSI-PUT.

       SCEN-RENDER-RESULT.
           IF WS-SCEN-RC = 3
               MOVE "1;33" TO WS-PUT-COLOR
               MOVE 11 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
               MOVE LBL-SC-GATE TO WS-PUT-TEXT  PERFORM ANSI-PUT
               MOVE WS-CLR-BASE TO WS-PUT-COLOR
               EXIT PARAGRAPH
           END-IF
           MOVE WS-CLR-BASE TO WS-PUT-COLOR
           MOVE 11 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
           MOVE LBL-SC-SCN TO WS-PUT-TEXT  PERFORM ANSI-PUT
           MOVE 11 TO WS-AT-ROW  MOVE 16 TO WS-AT-COL
           MOVE WS-SCEN-VERB TO WS-PUT-TEXT  PERFORM ANSI-PUT
           IF WS-SCEN-OK-FLAG = "Y"
               MOVE WS-CLR-HI TO WS-PUT-COLOR
               MOVE LBL-SC-OK TO WS-FLD-VAL
           ELSE
               MOVE "1;31" TO WS-PUT-COLOR
               MOVE LBL-SC-FAIL TO WS-FLD-VAL
           END-IF
           MOVE 11 TO WS-AT-ROW  MOVE 30 TO WS-AT-COL
           MOVE WS-FLD-VAL TO WS-PUT-TEXT  PERFORM ANSI-PUT
           MOVE WS-CLR-BASE TO WS-PUT-COLOR
           MOVE SPACES TO WS-SCEN-LINE2
           STRING "PASS=" FUNCTION TRIM(WS-SCEN-RPASS)
                  "  FAIL=" FUNCTION TRIM(WS-SCEN-RFAIL)
                  "  " FUNCTION TRIM(LBL-SC-ELAPSED) " "
                  FUNCTION TRIM(WS-SCEN-RELAPSED) "s"
                  DELIMITED BY SIZE INTO WS-SCEN-LINE2
           MOVE 12 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
           MOVE WS-SCEN-LINE2 TO WS-PUT-TEXT  PERFORM ANSI-PUT
           PERFORM VARYING WS-SCEN-FLD FROM 1 BY 1
                   UNTIL WS-SCEN-FLD > WS-SCEN-KCNT
               COMPUTE WS-AT-ROW = 13 + WS-SCEN-FLD
               MOVE 4 TO WS-AT-COL
               MOVE WS-SCEN-KEY(WS-SCEN-FLD) TO WS-PUT-TEXT
               PERFORM ANSI-PUT
           END-PERFORM.

       SCEN-RENDER-PLAIN.
           DISPLAY " "
           DISPLAY "== " FUNCTION TRIM(LBL-SCENTITLE)
           IF WS-SCEN-RAN NOT = "Y"
               DISPLAY FUNCTION TRIM(LBL-SC-HDR)
               DISPLAY "  " FUNCTION TRIM(LBL-SC-DESC-RECON)
               DISPLAY "  " FUNCTION TRIM(LBL-SC-DESC-CONC)
               DISPLAY "  " FUNCTION TRIM(LBL-SC-DESC-SMOKE)
               EXIT PARAGRAPH
           END-IF
           IF WS-SCEN-RC = 3
               DISPLAY FUNCTION TRIM(LBL-SC-GATE)
               EXIT PARAGRAPH
           END-IF
           IF WS-SCEN-OK-FLAG = "Y"
               MOVE LBL-SC-OK TO WS-FLD-VAL
           ELSE
               MOVE LBL-SC-FAIL TO WS-FLD-VAL
           END-IF
           DISPLAY FUNCTION TRIM(LBL-SC-SCN) " "
                   FUNCTION TRIM(WS-SCEN-VERB) "  "
                   FUNCTION TRIM(WS-FLD-VAL) "  PASS="
                   FUNCTION TRIM(WS-SCEN-RPASS) " FAIL="
                   FUNCTION TRIM(WS-SCEN-RFAIL) "  "
                   FUNCTION TRIM(LBL-SC-ELAPSED) " "
                   FUNCTION TRIM(WS-SCEN-RELAPSED) "s"
           PERFORM VARYING WS-SCEN-FLD FROM 1 BY 1
                   UNTIL WS-SCEN-FLD > WS-SCEN-KCNT
               DISPLAY "  " FUNCTION TRIM(WS-SCEN-KEY(WS-SCEN-FLD))
           END-PERFORM.

       REVS-TRAN.
           MOVE "PBNK-REVS"   TO WS-SCR-PFX
           MOVE LBL-REVSTITLE TO WS-SCR-TITLE
           MOVE LBL-PF-REVS   TO WS-SCR-PF
           MOVE SPACES        TO WS-ERR-MSG WS-OK-MSG
           IF NOT SCREEN-ON
               MOVE SPACES TO WS-PREFILL-TXN
               DISPLAY FUNCTION TRIM(LBL-REVSTITLE)
               EXIT PARAGRAPH
           END-IF
           PERFORM REVS-EVENT-LOOP.

       REVS-EVENT-LOOP.
           MOVE "N" TO WS-EXIT-FLAG
           PERFORM UNTIL WS-EXIT-FLAG = "Y"
               PERFORM REVS-RESET-ATTEMPT
               PERFORM REVS-RENDER
               IF WS-REVS-TXN = SPACES
                   PERFORM REVS-ACCEPT-TXN
               END-IF
               IF WS-REVS-BACK = "Y"
                   MOVE "Y" TO WS-EXIT-FLAG
               ELSE
                   PERFORM REVS-PREFLIGHT
                   IF WS-PF-LOADED = "Y"
                       PERFORM REVS-RENDER
                       PERFORM REVS-DO-ATTEMPT
                       IF WS-REVS-SUCCESS = "Y"
                           PERFORM REVS-JUMP-JRNL
                           MOVE "Y" TO WS-EXIT-FLAG
                       END-IF
                   END-IF
               END-IF
           END-PERFORM.

       REVS-RESET-ATTEMPT.
           MOVE SPACES TO WS-REVS-REASON
           MOVE "N" TO WS-PF-LOADED WS-REVS-BACK
           MOVE "N" TO WS-REVS-CONFIRMED WS-REVS-SUCCESS
           IF WS-PREFILL-TXN NOT = SPACES
               MOVE WS-PREFILL-TXN TO WS-REVS-TXN
               MOVE SPACES TO WS-PREFILL-TXN
           ELSE
               MOVE SPACES TO WS-REVS-TXN
           END-IF.

       REVS-SANITIZE-CMD.
           INSPECT WS-CMD-LINE REPLACING ALL X"0D" BY SPACE
           INSPECT WS-CMD-LINE REPLACING ALL X"0A" BY SPACE
           INSPECT WS-CMD-LINE REPLACING ALL X"09" BY SPACE
           MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-CMD-LINE))
                TO WS-CMD-NORM.

       REVS-ACCEPT-TXN.
           MOVE SPACES TO WS-ERR-MSG WS-OK-MSG
           MOVE 6 TO WS-AT-ROW  MOVE 22 TO WS-AT-COL
           PERFORM ANSI-CURSOR-AT
           PERFORM ANSI-SHOW-CURSOR
           MOVE SPACES TO WS-CMD-LINE
           ACCEPT WS-CMD-LINE
           PERFORM REVS-SANITIZE-CMD
           PERFORM ANSI-HIDE-CURSOR
           IF WS-CMD-NORM = SPACES OR WS-CMD-NORM = "B"
              OR WS-CMD-NORM = "BACK" OR WS-CMD-NORM = "MENU"
              OR WS-CMD-NORM = "EXIT" OR WS-CMD-NORM = "QUIT"
               MOVE "Y" TO WS-REVS-BACK
               EXIT PARAGRAPH
           END-IF
           MOVE FUNCTION TRIM(WS-CMD-LINE) TO WS-REVS-TXN.

       REVS-PREFLIGHT.
           MOVE "N" TO WS-PF-LOADED
           MOVE SPACES TO WS-ERR-MSG
           IF WS-REVS-TXN(1:18) IS NOT NUMERIC
               MOVE LBL-R-BADTXN TO WS-ERR-MSG
               EXIT PARAGRAPH
           END-IF
           MOVE WS-REVS-TXN TO HV-TXN
           MOVE SPACES TO HV-PF-STAT
           PERFORM PG-COMMIT
           EXEC SQL
               SELECT TO_CHAR(business_date,'YYYY-MM-DD'),
                      category, amount_jpy, status, account_number
                 INTO :HV-PF-BD, :HV-PF-CAT, :HV-PF-AMT,
                      :HV-PF-STAT, :HV-PF-ACCT
                 FROM transactions
                WHERE txn_id = :HV-TXN
           END-EXEC
           IF SQLCODE NOT = 0 OR HV-PF-STAT = SPACES
               MOVE LBL-R-NOTFOUND TO WS-ERR-MSG
               EXIT PARAGRAPH
           END-IF
           IF HV-PF-STAT NOT = "PT" AND HV-PF-STAT NOT = "SE"
               MOVE LBL-R-NOTREVERS TO WS-ERR-MSG
               EXIT PARAGRAPH
           END-IF
           MOVE "Y" TO WS-PF-LOADED.

       REVS-DO-ATTEMPT.
           PERFORM REVS-ENSURE-OPERATOR
           IF WS-OPERATOR = SPACES
               MOVE LBL-R-CANCELLED TO WS-ERR-MSG
               EXIT PARAGRAPH
           END-IF
           PERFORM REVS-RENDER
           PERFORM REVS-ACCEPT-REASON
           IF WS-REVS-REASON = SPACES
               MOVE LBL-R-CANCELLED TO WS-ERR-MSG
               EXIT PARAGRAPH
           END-IF
           PERFORM REVS-RENDER
           PERFORM REVS-CONFIRM
           IF WS-REVS-CONFIRMED NOT = "Y"
               MOVE LBL-R-CANCELLED TO WS-ERR-MSG
               EXIT PARAGRAPH
           END-IF
           PERFORM REVS-EXECUTE.

       REVS-ENSURE-OPERATOR.
           IF WS-OPERATOR NOT = SPACES
               EXIT PARAGRAPH
           END-IF
           MOVE 4 TO WS-AT-ROW  MOVE 22 TO WS-AT-COL
           PERFORM ANSI-CURSOR-AT
           PERFORM ANSI-SHOW-CURSOR
           MOVE SPACES TO WS-CMD-LINE
           ACCEPT WS-CMD-LINE
           PERFORM REVS-SANITIZE-CMD
           PERFORM ANSI-HIDE-CURSOR
           MOVE FUNCTION TRIM(WS-CMD-LINE) TO WS-OPERATOR.

       REVS-ACCEPT-REASON.
           MOVE 14 TO WS-AT-ROW  MOVE 22 TO WS-AT-COL
           PERFORM ANSI-CURSOR-AT
           PERFORM ANSI-SHOW-CURSOR
           MOVE SPACES TO WS-REVS-REASON
           ACCEPT WS-REVS-REASON
           INSPECT WS-REVS-REASON REPLACING ALL X"0D" BY SPACE
           INSPECT WS-REVS-REASON REPLACING ALL X"0A" BY SPACE
           INSPECT WS-REVS-REASON REPLACING ALL X"09" BY SPACE
           PERFORM ANSI-HIDE-CURSOR
           IF FUNCTION TRIM(WS-REVS-REASON) = SPACES
               MOVE SPACES TO WS-REVS-REASON
           END-IF.

       REVS-CONFIRM.
           MOVE "N" TO WS-REVS-CONFIRMED
           MOVE 18 TO WS-AT-ROW  MOVE 40 TO WS-AT-COL
           PERFORM ANSI-CURSOR-AT
           PERFORM ANSI-SHOW-CURSOR
           MOVE SPACES TO WS-CMD-LINE
           ACCEPT WS-CMD-LINE
           PERFORM REVS-SANITIZE-CMD
           PERFORM ANSI-HIDE-CURSOR
           IF WS-CMD-NORM = "Y" OR WS-CMD-NORM = "YES"
               MOVE "Y" TO WS-REVS-CONFIRMED
           END-IF.

       REVS-EXECUTE.
           MOVE "N" TO WS-REVS-SUCCESS
           IF WS-ALLOW-WRITE NOT = "Y"
               MOVE LBL-R-READONLY TO WS-ERR-MSG
               EXIT PARAGRAPH
           END-IF
           PERFORM REVS-GEN-REQID
           PERFORM REVS-MKDIR
           PERFORM REVS-WRITE-REQUEST
           IF WS-REQ-FS NOT = "00"
               MOVE LBL-R-ERR12 TO WS-ERR-MSG
               EXIT PARAGRAPH
           END-IF
           PERFORM REVS-CALL-SCRIPT
           EVALUATE WS-REVS-RC
               WHEN 0 CONTINUE
               WHEN 3
                   MOVE LBL-R-ERRGATE TO WS-ERR-MSG
                   EXIT PARAGRAPH
               WHEN 4
                   MOVE LBL-R-ERRTO TO WS-ERR-MSG
                   EXIT PARAGRAPH
               WHEN OTHER
                   MOVE LBL-R-ERR12 TO WS-ERR-MSG
                   EXIT PARAGRAPH
           END-EVALUATE
           PERFORM REVS-READ-RESULT
           IF WS-RES-FS NOT = "00"
               MOVE LBL-R-ERR12 TO WS-ERR-MSG
               EXIT PARAGRAPH
           END-IF
           IF FUNCTION TRIM(WS-RES-REQID) NOT =
              FUNCTION TRIM(WS-REQ-ID)
               MOVE LBL-R-ERR12 TO WS-ERR-MSG
               EXIT PARAGRAPH
           END-IF
           IF WS-RES-STATUS NOT = "00"
               PERFORM REVS-MAP-STATUS-ERR
               EXIT PARAGRAPH
           END-IF
           IF WS-RES-RVID(9:1) NOT = "9"
               MOVE LBL-R-ERR12 TO WS-ERR-MSG
               EXIT PARAGRAPH
           END-IF
           PERFORM REVS-VERIFY-PG
           IF WS-RV-CONFIRMED NOT = "Y"
               MOVE LBL-R-ERR12 TO WS-ERR-MSG
               EXIT PARAGRAPH
           END-IF
           MOVE "Y" TO WS-REVS-SUCCESS
           MOVE SPACES TO WS-ERR-MSG
           STRING FUNCTION TRIM(LBL-R-OK) " " WS-RES-RVID
                  DELIMITED BY SIZE INTO WS-OK-MSG.

       REVS-GEN-REQID.
           MOVE FUNCTION CURRENT-DATE TO WS-FUNC-DATE
           MOVE SPACES TO WS-REQ-ID
           STRING "R" WS-FUNC-DATE(1:16)
                  DELIMITED BY SIZE INTO WS-REQ-ID.

       REVS-MKDIR.
           MOVE SPACES TO WS-CMD
           STRING "mkdir -p " FUNCTION TRIM(WS-REVS-DIR)
                  DELIMITED BY SIZE INTO WS-CMD
           CALL "SYSTEM" USING WS-CMD.

       REVS-WRITE-REQUEST.
           OPEN OUTPUT REVREQ-FILE
           IF WS-REQ-FS NOT = "00"
               EXIT PARAGRAPH
           END-IF
           MOVE WS-REQ-ID TO REVREQ-REC      WRITE REVREQ-REC
           MOVE WS-REVS-TXN TO REVREQ-REC    WRITE REVREQ-REC
           MOVE WS-REVS-REASON TO REVREQ-REC WRITE REVREQ-REC
           MOVE WS-OPERATOR TO REVREQ-REC    WRITE REVREQ-REC
           CLOSE REVREQ-FILE.

       REVS-CALL-SCRIPT.
           MOVE SPACES TO WS-CMD
           STRING "rm -f " FUNCTION TRIM(WS-RES-PATH)
                  DELIMITED BY SIZE INTO WS-CMD
           CALL "SYSTEM" USING WS-CMD
           MOVE SPACES TO WS-CMD
           STRING "bash " FUNCTION TRIM(WS-REVS-SCRIPT)
                  " " FUNCTION TRIM(WS-REVS-DIR)
                  DELIMITED BY SIZE INTO WS-CMD
           CALL "SYSTEM" USING WS-CMD
           DIVIDE RETURN-CODE BY 256 GIVING WS-REVS-RC.

       REVS-READ-RESULT.
           MOVE SPACES TO WS-RES-LINE WS-RES-REQID
                          WS-RES-STATUS WS-RES-RVID WS-RES-INDOUBT
           MOVE "N" TO WS-RES-FOUND
           OPEN INPUT REVRES-FILE
           IF WS-RES-FS NOT = "00"
               EXIT PARAGRAPH
           END-IF
           READ REVRES-FILE
               AT END CONTINUE
               NOT AT END
                   MOVE REVRES-REC TO WS-RES-LINE
                   MOVE "Y" TO WS-RES-FOUND
           END-READ
           CLOSE REVRES-FILE
           IF WS-RES-FOUND = "Y"
               PERFORM REVS-PARSE-RESULT
           ELSE
               MOVE "10" TO WS-RES-FS
           END-IF.

       REVS-PARSE-RESULT.
           MOVE 1 TO WS-RES-FLD
           MOVE 0 TO WS-RES-IDX2
           PERFORM VARYING WS-RES-IDX FROM 1 BY 1
                   UNTIL WS-RES-IDX > 160
               MOVE WS-RES-LINE(WS-RES-IDX:1) TO WS-RES-CH
               IF WS-RES-CH = "|"
                   ADD 1 TO WS-RES-FLD
                   MOVE 0 TO WS-RES-IDX2
               ELSE
                   ADD 1 TO WS-RES-IDX2
                   EVALUATE WS-RES-FLD
                       WHEN 1
                           IF WS-RES-IDX2 <= 20
                               MOVE WS-RES-CH
                                    TO WS-RES-REQID(WS-RES-IDX2:1)
                           END-IF
                       WHEN 2
                           IF WS-RES-IDX2 <= 2
                               MOVE WS-RES-CH
                                    TO WS-RES-STATUS(WS-RES-IDX2:1)
                           END-IF
                       WHEN 3
                           IF WS-RES-IDX2 <= 18
                               MOVE WS-RES-CH
                                    TO WS-RES-RVID(WS-RES-IDX2:1)
                           END-IF
                       WHEN 4
                           IF WS-RES-IDX2 <= 1
                               MOVE WS-RES-CH
                                    TO WS-RES-INDOUBT(WS-RES-IDX2:1)
                           END-IF
                       WHEN OTHER CONTINUE
                   END-EVALUATE
               END-IF
           END-PERFORM.

       REVS-VERIFY-PG.
           MOVE "N" TO WS-RV-CONFIRMED
           MOVE WS-RES-RVID TO HV-TXN
           PERFORM PG-COMMIT
           EXEC SQL
               SELECT COUNT(*) INTO :HV-RV-CNT FROM transactions
                WHERE txn_id = :HV-TXN AND status = 'RV'
           END-EXEC
           IF SQLCODE = 0 AND HV-RV-CNT = 1
               MOVE "Y" TO WS-RV-CONFIRMED
           END-IF.

       REVS-MAP-STATUS-ERR.
           EVALUATE WS-RES-STATUS
               WHEN "04" MOVE LBL-R-ERR04 TO WS-ERR-MSG
               WHEN "08" MOVE LBL-R-ERR08 TO WS-ERR-MSG
               WHEN "12" MOVE LBL-R-ERR12 TO WS-ERR-MSG
               WHEN OTHER MOVE LBL-R-ERR12 TO WS-ERR-MSG
           END-EVALUATE.

       REVS-JUMP-JRNL.
           MOVE WS-RES-RVID TO HV-TXN
           PERFORM PG-COMMIT
           EXEC SQL
               SELECT COUNT(*) INTO :HV-RANK FROM transactions
                WHERE txn_id <= :HV-TXN
           END-EXEC
           IF HV-RANK < 1
               MOVE 1 TO WS-PAGE
           ELSE
               COMPUTE WS-PAGE =
                   FUNCTION INTEGER((HV-RANK - 1) / WS-PAGE-SIZE) + 1
           END-IF
           PERFORM JRNL-COUNT
           PERFORM JRNL-LOAD-PAGE
           PERFORM JRNL-RENDER
           IF WS-OK-MSG NOT = SPACES
               MOVE WS-CLR-HI TO WS-PUT-COLOR
               MOVE 24 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
               MOVE WS-OK-MSG TO WS-PUT-TEXT  PERFORM ANSI-PUT
               MOVE WS-CLR-BASE TO WS-PUT-COLOR
           END-IF
           PERFORM JRNL-EVENT-LOOP.

       REVS-PARSE-ROW.
           MOVE 0 TO WS-ROW-PICK
           MOVE "N" TO WS-ROW-OK
           IF WS-CMD-NORM(1:1) NOT = "R"
               EXIT PARAGRAPH
           END-IF
           IF WS-CMD-NORM(4:17) NOT = SPACES
               EXIT PARAGRAPH
           END-IF
           MOVE WS-CMD-NORM(2:2) TO WS-ROW-DIGITS
           IF FUNCTION TRIM(WS-ROW-DIGITS) = SPACES
               EXIT PARAGRAPH
           END-IF
           IF FUNCTION TRIM(WS-ROW-DIGITS) IS NUMERIC
               COMPUTE WS-ROW-PICK =
                   FUNCTION NUMVAL(WS-ROW-DIGITS)
           END-IF
           IF WS-ROW-PICK >= 1 AND WS-ROW-PICK <= 10
               MOVE "Y" TO WS-ROW-OK
           ELSE
               MOVE 0 TO WS-ROW-PICK
           END-IF.

       REVS-RENDER.
           PERFORM RENDER-HDR-ANSI
           MOVE LBL-R-OPER TO WS-FLD-LBL
           MOVE WS-OPERATOR TO WS-FLD-VAL
           MOVE 4 TO WS-FLD-LINE  PERFORM RENDER-FIELD
           MOVE LBL-R-TXN TO WS-FLD-LBL
           MOVE WS-REVS-TXN TO WS-FLD-VAL
           MOVE 6 TO WS-FLD-LINE  PERFORM RENDER-FIELD
           IF WS-PF-LOADED = "Y"
               PERFORM REVS-RENDER-DETAIL
               MOVE LBL-R-REASON TO WS-FLD-LBL
               MOVE WS-REVS-REASON TO WS-FLD-VAL
               MOVE 14 TO WS-FLD-LINE  PERFORM RENDER-FIELD
               MOVE "1;33" TO WS-PUT-COLOR
               MOVE 18 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
               MOVE LBL-R-CONFIRM TO WS-PUT-TEXT  PERFORM ANSI-PUT
               MOVE WS-CLR-BASE TO WS-PUT-COLOR
           END-IF
           IF WS-ALLOW-WRITE NOT = "Y"
               MOVE "1;33" TO WS-PUT-COLOR
               MOVE 19 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
               MOVE LBL-R-READONLY TO WS-PUT-TEXT  PERFORM ANSI-PUT
               MOVE WS-CLR-BASE TO WS-PUT-COLOR
           END-IF
           PERFORM REVS-RENDER-FOOT.

       REVS-RENDER-DETAIL.
           MOVE LBL-R-BD TO WS-FLD-LBL
           MOVE HV-PF-BD TO WS-FLD-VAL
           MOVE 8 TO WS-FLD-LINE  PERFORM RENDER-FIELD
           MOVE LBL-R-CAT TO WS-FLD-LBL
           MOVE HV-PF-CAT TO HV-CAT
           PERFORM MAP-CAT
           MOVE WS-MVAL TO WS-FLD-VAL
           MOVE 9 TO WS-FLD-LINE  PERFORM RENDER-FIELD
           MOVE LBL-R-AMT TO WS-FLD-LBL
           MOVE HV-PF-AMT TO WS-PF-AMT-EDIT
           MOVE WS-PF-AMT-EDIT TO WS-FLD-VAL
           MOVE 10 TO WS-FLD-LINE  PERFORM RENDER-FIELD
           MOVE LBL-R-STAT TO WS-FLD-LBL
           MOVE HV-PF-STAT TO WS-FLD-VAL
           MOVE 11 TO WS-FLD-LINE  PERFORM RENDER-FIELD.

       REVS-RENDER-FOOT.
           MOVE 21 TO WS-SEP-ROW  PERFORM DRAW-SEP
           MOVE WS-CLR-REV TO WS-PUT-COLOR
           MOVE 23 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
           MOVE WS-SCR-PF TO WS-PUT-TEXT  PERFORM ANSI-PUT
           IF WS-OK-MSG NOT = SPACES
               MOVE WS-CLR-HI TO WS-PUT-COLOR
               MOVE 24 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
               MOVE WS-OK-MSG TO WS-PUT-TEXT  PERFORM ANSI-PUT
           END-IF
           IF WS-ERR-MSG NOT = SPACES
               MOVE "1;31" TO WS-PUT-COLOR
               MOVE 24 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
               MOVE WS-ERR-MSG TO WS-PUT-TEXT  PERFORM ANSI-PUT
           END-IF
           MOVE WS-CLR-BASE TO WS-PUT-COLOR.

        POST-TRAN.
            MOVE "PBNK-POST"   TO WS-SCR-PFX
            MOVE LBL-POSTTITLE TO WS-SCR-TITLE
            MOVE LBL-PF-POST   TO WS-SCR-PF
            MOVE SPACES TO WS-ERR-MSG WS-OK-MSG WS-STATUS-MSG
            MOVE 0 TO WS-PNUM
            IF NOT SCREEN-ON
                DISPLAY FUNCTION TRIM(LBL-POSTTITLE)
                EXIT PARAGRAPH
            END-IF
            PERFORM POST-EVENT-LOOP.

        POST-EVENT-LOOP.
            MOVE "N" TO WS-EXIT-FLAG
            PERFORM UNTIL WS-EXIT-FLAG = "Y"
                PERFORM POST-RENDER
                PERFORM POST-READ-CMD
                EVALUATE WS-CMD-NORM
                    WHEN SPACES
                    WHEN "B"
                    WHEN "BACK"
                    WHEN "MENU"
                    WHEN "EXIT"
                    WHEN "QUIT"
                        MOVE "Y" TO WS-EXIT-FLAG
                    WHEN "A"
                    WHEN "ADD"
                        PERFORM POST-ADD-ITEM
                    WHEN "C"
                    WHEN "CLEAR"
                        MOVE 0 TO WS-PNUM
                        MOVE SPACES TO WS-ERR-MSG
                        MOVE LBL-P-CLEARED TO WS-OK-MSG
                    WHEN "G"
                    WHEN "GO"
                    WHEN "POST"
                        PERFORM POST-SUBMIT
                        IF WS-PRES-STATUS = "OK" OR
                           WS-PRES-STATUS = "PARTIAL"
                            PERFORM POST-JUMP-JRNL
                            MOVE "Y" TO WS-EXIT-FLAG
                        END-IF
                    WHEN OTHER
                        CONTINUE
                END-EVALUATE
            END-PERFORM.

        POST-READ-CMD.
            PERFORM PG-COMMIT
            MOVE 22 TO WS-AT-ROW  MOVE 22 TO WS-AT-COL
            PERFORM ANSI-CURSOR-AT
            PERFORM ANSI-SHOW-CURSOR
            MOVE SPACES TO WS-CMD-LINE
            ACCEPT WS-CMD-LINE
            PERFORM POST-SANITIZE
            PERFORM ANSI-HIDE-CURSOR.

        POST-SANITIZE.
            INSPECT WS-CMD-LINE REPLACING ALL X"0D" BY SPACE
            INSPECT WS-CMD-LINE REPLACING ALL X"0A" BY SPACE
            INSPECT WS-CMD-LINE REPLACING ALL X"09" BY SPACE
            MOVE FUNCTION UPPER-CASE(FUNCTION TRIM(WS-CMD-LINE))
                 TO WS-CMD-NORM.

        POST-ADD-ITEM.
            MOVE SPACES TO WS-ERR-MSG WS-OK-MSG
            IF WS-PNUM >= 10
                MOVE LBL-P-FULL TO WS-ERR-MSG
                EXIT PARAGRAPH
            END-IF
            MOVE 16 TO WS-AT-ROW  MOVE 35 TO WS-AT-COL
            PERFORM POST-ACCEPT-FIELD
            IF WS-POST-BACK = "Y"
                EXIT PARAGRAPH
            END-IF
            EVALUATE WS-CMD-NORM
                WHEN "D" MOVE "10" TO WS-POST-CAT
                WHEN "W" MOVE "20" TO WS-POST-CAT
                WHEN "T" MOVE "30" TO WS-POST-CAT
                WHEN OTHER
                    MOVE LBL-P-BADCAT TO WS-ERR-MSG
                    EXIT PARAGRAPH
            END-EVALUATE
            MOVE 17 TO WS-AT-ROW  MOVE 18 TO WS-AT-COL
            PERFORM POST-ACCEPT-FIELD
            IF WS-POST-BACK = "Y"
                EXIT PARAGRAPH
            END-IF
            MOVE WS-CMD-NORM(1:13) TO WS-POST-PAYER
            MOVE SPACES TO WS-POST-PAYEE
            IF WS-POST-CAT = "30"
                MOVE 18 TO WS-AT-ROW  MOVE 24 TO WS-AT-COL
                PERFORM POST-ACCEPT-FIELD
                IF WS-POST-BACK = "Y"
                    EXIT PARAGRAPH
                END-IF
                MOVE WS-CMD-NORM(1:13) TO WS-POST-PAYEE
            END-IF
            MOVE 19 TO WS-AT-ROW  MOVE 18 TO WS-AT-COL
            PERFORM POST-ACCEPT-FIELD
            IF WS-POST-BACK = "Y"
                EXIT PARAGRAPH
            END-IF
            MOVE 0 TO WS-POST-AMT
            COMPUTE WS-POST-AMT = FUNCTION NUMVAL(WS-CMD-NORM)
            PERFORM POST-VALIDATE-ITEM
            IF WS-ERR-MSG = SPACES
                ADD 1 TO WS-PNUM
                MOVE WS-POST-CAT   TO PI-CAT(WS-PNUM)
                MOVE WS-POST-PAYER TO PI-PAYER(WS-PNUM)
                MOVE WS-POST-PAYEE TO PI-PAYEE(WS-PNUM)
                MOVE WS-POST-AMT   TO PI-AMT(WS-PNUM)
                MOVE SPACES        TO PI-DESC(WS-PNUM)
                MOVE LBL-P-ADDED TO WS-OK-MSG
            END-IF.

        POST-ACCEPT-FIELD.
            PERFORM ANSI-CURSOR-AT
            PERFORM ANSI-SHOW-CURSOR
            MOVE SPACES TO WS-CMD-LINE
            ACCEPT WS-CMD-LINE
            PERFORM POST-SANITIZE
            PERFORM ANSI-HIDE-CURSOR
            MOVE "N" TO WS-POST-BACK
            IF WS-CMD-NORM = SPACES OR WS-CMD-NORM = "B"
               OR WS-CMD-NORM = "BACK"
                MOVE "Y" TO WS-POST-BACK
            END-IF.

        POST-VALIDATE-ITEM.
            MOVE SPACES TO WS-ERR-MSG
            IF WS-POST-AMT = 0
                MOVE LBL-P-BADAMT TO WS-ERR-MSG
                EXIT PARAGRAPH
            END-IF
            IF WS-POST-PAYER(1:12) = "001001000000"
                MOVE LBL-P-SYSACCT TO WS-ERR-MSG
                EXIT PARAGRAPH
            END-IF
            MOVE WS-POST-PAYER TO HV-ACCT
            PERFORM POST-CHECK-ACCT
            IF WS-NF-FLAG = "Y"
                MOVE LBL-P-BADACCT TO WS-ERR-MSG
                EXIT PARAGRAPH
            END-IF
            IF WS-POST-CAT = "30"
                IF WS-POST-PAYEE(1:12) = "001001000000"
                    MOVE LBL-P-SYSACCT TO WS-ERR-MSG
                    EXIT PARAGRAPH
                END-IF
                IF FUNCTION TRIM(WS-POST-PAYER) =
                   FUNCTION TRIM(WS-POST-PAYEE)
                    MOVE LBL-P-SELFXFER TO WS-ERR-MSG
                    EXIT PARAGRAPH
                END-IF
                MOVE WS-POST-PAYEE TO HV-ACCT
                PERFORM POST-CHECK-ACCT
                IF WS-NF-FLAG = "Y"
                    MOVE LBL-P-BADACCT TO WS-ERR-MSG
                END-IF
            END-IF.

        POST-CHECK-ACCT.
            MOVE "N" TO WS-NF-FLAG
            MOVE SPACES TO HV-ASTATUS
            PERFORM PG-COMMIT
            EXEC SQL
                SELECT acct_status INTO :HV-ASTATUS
                  FROM accounts WHERE acct_number = :HV-ACCT
            END-EXEC
            IF SQLCODE NOT = 0 OR HV-ASTATUS NOT = "A"
                MOVE "Y" TO WS-NF-FLAG
            END-IF.

        POST-SUBMIT.
            MOVE SPACES TO WS-ERR-MSG WS-OK-MSG
            MOVE SPACES TO WS-PRES-STATUS
            IF WS-PNUM = 0
                MOVE LBL-P-EMPTY TO WS-ERR-MSG
                EXIT PARAGRAPH
            END-IF
            IF WS-ALLOW-WRITE NOT = "Y"
                MOVE LBL-P-READONLY TO WS-ERR-MSG
                EXIT PARAGRAPH
            END-IF
            PERFORM POST-RENDER
            MOVE 20 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
            MOVE "1;33" TO WS-PUT-COLOR
            MOVE LBL-P-CONFIRM TO WS-PUT-TEXT  PERFORM ANSI-PUT
            MOVE WS-CLR-BASE TO WS-PUT-COLOR
            MOVE 20 TO WS-AT-ROW  MOVE 53 TO WS-AT-COL
            PERFORM ANSI-CURSOR-AT
            PERFORM ANSI-SHOW-CURSOR
            MOVE SPACES TO WS-CMD-LINE
            ACCEPT WS-CMD-LINE
            PERFORM POST-SANITIZE
            PERFORM ANSI-HIDE-CURSOR
            IF WS-CMD-NORM NOT = "Y" AND WS-CMD-NORM NOT = "YES"
                MOVE LBL-P-CANCELLED TO WS-ERR-MSG
                EXIT PARAGRAPH
            END-IF
            PERFORM POST-WRITE-REQUEST
            PERFORM POST-CALL-SCRIPT
            PERFORM POST-READ-RESULT
            PERFORM POST-MAP-RESULT.

        POST-WRITE-REQUEST.
            MOVE SPACES TO WS-CMD
            STRING "mkdir -p " FUNCTION TRIM(WS-POST-DIR)
                   DELIMITED BY SIZE INTO WS-CMD
            CALL "SYSTEM" USING WS-CMD
            OPEN OUTPUT POSTREQ-FILE
            IF WS-PREQ-FS NOT = "00"
                EXIT PARAGRAPH
            END-IF
            MOVE SPACES TO POSTREQ-REC
            MOVE WS-OPERATOR TO POSTREQ-REC(1:20)
            WRITE POSTREQ-REC
            MOVE SPACES TO POSTREQ-REC
            MOVE WS-PNUM TO POSTREQ-REC(1:2)
            WRITE POSTREQ-REC
            PERFORM VARYING WS-PIDX FROM 1 BY 1 UNTIL WS-PIDX > WS-PNUM
                MOVE SPACES TO POSTREQ-REC
                MOVE PI-CAT(WS-PIDX)   TO POSTREQ-REC(1:2)
                MOVE PI-PAYER(WS-PIDX) TO POSTREQ-REC(3:13)
                MOVE PI-PAYEE(WS-PIDX) TO POSTREQ-REC(16:13)
                MOVE PI-AMT(WS-PIDX)   TO POSTREQ-REC(29:15)
                MOVE PI-DESC(WS-PIDX)  TO POSTREQ-REC(44:40)
                WRITE POSTREQ-REC
            END-PERFORM
            CLOSE POSTREQ-FILE.

        POST-CALL-SCRIPT.
            MOVE SPACES TO WS-CMD
            STRING "rm -f " FUNCTION TRIM(WS-PRES-PATH)
                   DELIMITED BY SIZE INTO WS-CMD
            CALL "SYSTEM" USING WS-CMD
            MOVE SPACES TO WS-CMD
            STRING "bash " FUNCTION TRIM(WS-POST-SCRIPT)
                   " " FUNCTION TRIM(WS-POST-DIR)
                   DELIMITED BY SIZE INTO WS-CMD
            CALL "SYSTEM" USING WS-CMD
            DIVIDE RETURN-CODE BY 256 GIVING WS-POST-RC.

        POST-READ-RESULT.
            MOVE SPACES TO WS-PRES-LINE WS-PRES-STATUS
                           WS-PRES-POSTED WS-PRES-REJECT WS-PRES-REASONS
            OPEN INPUT POSTRES-FILE
            IF WS-PRES-FS NOT = "00"
                EXIT PARAGRAPH
            END-IF
            READ POSTRES-FILE
                AT END CONTINUE
                NOT AT END MOVE POSTRES-REC TO WS-PRES-LINE
            END-READ
            CLOSE POSTRES-FILE
            PERFORM POST-PARSE-RESULT.

        POST-PARSE-RESULT.
            MOVE 1 TO WS-PRES-FLD
            MOVE 0 TO WS-PRES-J
            PERFORM VARYING WS-PRES-IDX FROM 1 BY 1
                    UNTIL WS-PRES-IDX > 160
                MOVE WS-PRES-LINE(WS-PRES-IDX:1) TO WS-PRES-CH
                IF WS-PRES-CH = "|"
                    ADD 1 TO WS-PRES-FLD
                    MOVE 0 TO WS-PRES-J
                ELSE
                    ADD 1 TO WS-PRES-J
                    EVALUATE WS-PRES-FLD
                        WHEN 1
                            IF WS-PRES-J <= 10
                                MOVE WS-PRES-CH
                                     TO WS-PRES-STATUS(WS-PRES-J:1)
                            END-IF
                        WHEN 2
                            IF WS-PRES-J <= 7
                                MOVE WS-PRES-CH
                                     TO WS-PRES-POSTED(WS-PRES-J:1)
                            END-IF
                        WHEN 3
                            IF WS-PRES-J <= 7
                                MOVE WS-PRES-CH
                                     TO WS-PRES-REJECT(WS-PRES-J:1)
                            END-IF
                        WHEN 6
                            IF WS-PRES-J <= 40
                                MOVE WS-PRES-CH
                                     TO WS-PRES-REASONS(WS-PRES-J:1)
                            END-IF
                        WHEN OTHER CONTINUE
                    END-EVALUATE
                END-IF
            END-PERFORM.

        POST-MAP-RESULT.
            MOVE SPACES TO WS-ERR-MSG WS-OK-MSG
            EVALUATE FUNCTION TRIM(WS-PRES-STATUS)
                WHEN "OK"
                    MOVE 0 TO WS-PNUM
                    STRING FUNCTION TRIM(LBL-P-OK) " "
                           FUNCTION TRIM(WS-PRES-POSTED)
                           DELIMITED BY SIZE INTO WS-OK-MSG
                WHEN "PARTIAL"
                    MOVE 0 TO WS-PNUM
                    STRING FUNCTION TRIM(LBL-P-OK) " "
                           FUNCTION TRIM(WS-PRES-POSTED)
                           " / NG " FUNCTION TRIM(WS-PRES-REJECT)
                           " " FUNCTION TRIM(WS-PRES-REASONS)
                           DELIMITED BY SIZE INTO WS-OK-MSG
                WHEN "ALREADY"
                    MOVE LBL-P-ALREADY TO WS-ERR-MSG
                WHEN "ALLREJECT"
                    STRING FUNCTION TRIM(LBL-P-ALLREJECT) " "
                           FUNCTION TRIM(WS-PRES-REASONS)
                           DELIMITED BY SIZE INTO WS-ERR-MSG
                WHEN OTHER
                    MOVE LBL-P-ERR TO WS-ERR-MSG
            END-EVALUATE.

        POST-JUMP-JRNL.
            MOVE WS-POST-BDATE TO HV-BDATE
            PERFORM PG-COMMIT
            MOVE 0 TO HV-RANK
            EXEC SQL
                SELECT COUNT(*) INTO :HV-RANK FROM transactions
                 WHERE business_date <= CAST(:HV-BDATE AS DATE)
            END-EXEC
            IF HV-RANK < 1
                MOVE 1 TO WS-PAGE
            ELSE
                COMPUTE WS-PAGE =
                    FUNCTION INTEGER((HV-RANK - 1) / WS-PAGE-SIZE) + 1
            END-IF
            PERFORM JRNL-COUNT
            PERFORM JRNL-LOAD-PAGE
            PERFORM JRNL-RENDER
            IF WS-OK-MSG NOT = SPACES
                MOVE WS-CLR-HI TO WS-PUT-COLOR
                MOVE 24 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
                MOVE WS-OK-MSG TO WS-PUT-TEXT  PERFORM ANSI-PUT
                MOVE WS-CLR-BASE TO WS-PUT-COLOR
            END-IF
            PERFORM JRNL-EVENT-LOOP.

        POST-RENDER.
            PERFORM RENDER-HDR-ANSI
            MOVE LBL-P-BDATE TO WS-FLD-LBL
            MOVE WS-POST-BDATE TO WS-FLD-VAL
            MOVE 4 TO WS-FLD-LINE  PERFORM RENDER-FIELD
            MOVE WS-CLR-HI TO WS-PUT-COLOR
            MOVE 5 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
            MOVE LBL-P-HDR TO WS-PUT-TEXT  PERFORM ANSI-PUT
            MOVE WS-CLR-BASE TO WS-PUT-COLOR
            PERFORM VARYING WS-PIDX FROM 1 BY 1 UNTIL WS-PIDX > WS-PNUM
                COMPUTE WS-FLD-LINE = 5 + WS-PIDX
                MOVE 4 TO WS-FLD-COL
                MOVE PI-CAT(WS-PIDX) TO WS-FLD-VAL  PERFORM RENDER-AT
                MOVE 8 TO WS-FLD-COL
                MOVE PI-PAYER(WS-PIDX) TO WS-FLD-VAL  PERFORM RENDER-AT
                MOVE 24 TO WS-FLD-COL
                MOVE PI-PAYEE(WS-PIDX) TO WS-FLD-VAL  PERFORM RENDER-AT
                MOVE PI-AMT(WS-PIDX) TO WS-POST-AMT-DISP
                MOVE 42 TO WS-FLD-COL
                MOVE WS-POST-AMT-DISP TO WS-FLD-VAL  PERFORM RENDER-AT
            END-PERFORM
            MOVE WS-CLR-BASE TO WS-PUT-COLOR
            MOVE 16 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
            MOVE LBL-P-CATQ TO WS-PUT-TEXT  PERFORM ANSI-PUT
            MOVE 17 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
            MOVE LBL-P-ACCTQ TO WS-PUT-TEXT  PERFORM ANSI-PUT
            MOVE 18 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
            MOVE LBL-P-PAYEEQ TO WS-PUT-TEXT  PERFORM ANSI-PUT
            MOVE 19 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
            MOVE LBL-P-AMTQ TO WS-PUT-TEXT  PERFORM ANSI-PUT
            IF WS-ALLOW-WRITE NOT = "Y"
                MOVE "1;33" TO WS-PUT-COLOR
                MOVE 19 TO WS-AT-ROW  MOVE 40 TO WS-AT-COL
                MOVE LBL-P-READONLY TO WS-PUT-TEXT  PERFORM ANSI-PUT
                MOVE WS-CLR-BASE TO WS-PUT-COLOR
            END-IF
            PERFORM POST-RENDER-FOOT.

        POST-RENDER-FOOT.
            MOVE 21 TO WS-SEP-ROW  PERFORM DRAW-SEP
            MOVE WS-CLR-BASE TO WS-PUT-COLOR
            MOVE 22 TO WS-AT-ROW  MOVE 4 TO WS-AT-COL
            MOVE LBL-CMDPROMPT TO WS-PUT-TEXT  PERFORM ANSI-PUT
            MOVE WS-CLR-REV TO WS-PUT-COLOR
            MOVE 23 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
            MOVE WS-SCR-PF TO WS-PUT-TEXT  PERFORM ANSI-PUT
            IF WS-OK-MSG NOT = SPACES
                MOVE WS-CLR-HI TO WS-PUT-COLOR
                MOVE 24 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
                MOVE WS-OK-MSG TO WS-PUT-TEXT  PERFORM ANSI-PUT
            END-IF
            IF WS-ERR-MSG NOT = SPACES
                MOVE "1;31" TO WS-PUT-COLOR
                MOVE 24 TO WS-AT-ROW  MOVE 2 TO WS-AT-COL
                MOVE WS-ERR-MSG TO WS-PUT-TEXT  PERFORM ANSI-PUT
            END-IF
            MOVE WS-CLR-BASE TO WS-PUT-COLOR.

       END PROGRAM OPER-CONSOLE.
