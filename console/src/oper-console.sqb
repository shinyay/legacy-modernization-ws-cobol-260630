               WHEN "CRLABEL"      MOVE WS-MVAL TO LBL-CRLABEL
               WHEN "BALOK"        MOVE WS-MVAL TO LBL-BALOK
               WHEN "BALNG"        MOVE WS-MVAL TO LBL-BALNG
               WHEN "READY"        MOVE WS-MVAL TO LBL-READY
               WHEN "RUNNING"      MOVE WS-MVAL TO LBL-RUNNING
               WHEN "DONEMSG"      MOVE WS-MVAL TO LBL-DONEMSG
               WHEN "JC_TXN"       MOVE WS-MVAL TO LBL-JC-TXN
               WHEN "JC_CAT"       MOVE WS-MVAL TO LBL-JC-CAT
               WHEN "JC_DR"        MOVE WS-MVAL TO LBL-JC-DR
               WHEN "JC_CR"        MOVE WS-MVAL TO LBL-JC-CR
               WHEN "JC_AMT"       MOVE WS-MVAL TO LBL-JC-AMT
               WHEN "CAT10"        MOVE WS-MVAL TO LBL-CAT10
               WHEN "CAT20"        MOVE WS-MVAL TO LBL-CAT20
               WHEN "CAT30"        MOVE WS-MVAL TO LBL-CAT30
               WHEN "CAT40"        MOVE WS-MVAL TO LBL-CAT40
               WHEN "CATRV"        MOVE WS-MVAL TO LBL-CATRV
               WHEN "INVALIDTRAN"  MOVE WS-MVAL TO LBL-INVALIDTRAN
               WHEN "NOTIMPL"      MOVE WS-MVAL TO LBL-NOTIMPL
               WHEN "PAGEOF"       MOVE WS-MVAL TO LBL-PAGEOF
               WHEN "PRESSENTER"   MOVE WS-MVAL TO LBL-PRESSENTER
               WHEN "M_CUST"       MOVE WS-MVAL TO LBL-M-CUST
               WHEN "M_HIST"       MOVE WS-MVAL TO LBL-M-HIST
               WHEN "KEYPROMPT"    MOVE WS-MVAL TO LBL-KEYPROMPT
               WHEN "CMDPROMPT"    MOVE WS-MVAL TO LBL-CMDPROMPT
               WHEN "NOTFOUND"     MOVE WS-MVAL TO LBL-NOTFOUND
               WHEN "PF_INQ"       MOVE WS-MVAL TO LBL-PF-INQ
               WHEN "PF_PAGE"      MOVE WS-MVAL TO LBL-PF-PAGE
               WHEN "ACCTTITLE"    MOVE WS-MVAL TO LBL-ACCTTITLE
               WHEN "A_ANO"        MOVE WS-MVAL TO LBL-A-ANO
               WHEN "A_NAME"       MOVE WS-MVAL TO LBL-A-NAME
               WHEN "A_BRANCH"     MOVE WS-MVAL TO LBL-A-BRANCH
               WHEN "A_PROD"       MOVE WS-MVAL TO LBL-A-PROD
               WHEN "A_STATUS"     MOVE WS-MVAL TO LBL-A-STATUS
               WHEN "A_CUST"       MOVE WS-MVAL TO LBL-A-CUST
               WHEN "A_OPENED"     MOVE WS-MVAL TO LBL-A-OPENED
               WHEN "A_DORM"       MOVE WS-MVAL TO LBL-A-DORM
               WHEN "A_BAL"        MOVE WS-MVAL TO LBL-A-BAL
               WHEN "A_AVAIL"      MOVE WS-MVAL TO LBL-A-AVAIL
               WHEN "A_HOLD"       MOVE WS-MVAL TO LBL-A-HOLD
               WHEN "A_TXNCNT"     MOVE WS-MVAL TO LBL-A-TXNCNT
               WHEN "CUSTTITLE"    MOVE WS-MVAL TO LBL-CUSTTITLE
               WHEN "C_NAME"       MOVE WS-MVAL TO LBL-C-NAME
               WHEN "C_KANA"       MOVE WS-MVAL TO LBL-C-KANA
               WHEN "C_STATUS"     MOVE WS-MVAL TO LBL-C-STATUS
               WHEN "C_TIER"       MOVE WS-MVAL TO LBL-C-TIER
               WHEN "C_PHONE"      MOVE WS-MVAL TO LBL-C-PHONE
               WHEN "C_ADDR"       MOVE WS-MVAL TO LBL-C-ADDR
               WHEN "C_ACCTS"      MOVE WS-MVAL TO LBL-C-ACCTS
               WHEN "C_TOTAL"      MOVE WS-MVAL TO LBL-C-TOTAL
               WHEN "HISTTITLE"    MOVE WS-MVAL TO LBL-HISTTITLE
               WHEN "H_DATE"       MOVE WS-MVAL TO LBL-H-DATE
               WHEN "H_TXN"        MOVE WS-MVAL TO LBL-H-TXN
               WHEN "H_ROLE"       MOVE WS-MVAL TO LBL-H-ROLE
               WHEN "H_AMT"        MOVE WS-MVAL TO LBL-H-AMT
               WHEN "H_BAL"        MOVE WS-MVAL TO LBL-H-BAL
               WHEN "AUDTTITLE"    MOVE WS-MVAL TO LBL-AUDTTITLE
               WHEN "AU_TS"        MOVE WS-MVAL TO LBL-AU-TS
               WHEN "AU_SS"        MOVE WS-MVAL TO LBL-AU-SS
               WHEN "AU_ACT"       MOVE WS-MVAL TO LBL-AU-ACT
               WHEN "AU_SEV"       MOVE WS-MVAL TO LBL-AU-SEV
               WHEN "AU_TGT"       MOVE WS-MVAL TO LBL-AU-TGT
               WHEN "M_REVS"       MOVE WS-MVAL TO LBL-M-REVS
               WHEN "REVSTITLE"    MOVE WS-MVAL TO LBL-REVSTITLE
               WHEN "PF_REVS"      MOVE WS-MVAL TO LBL-PF-REVS
               WHEN "R_TXN"        MOVE WS-MVAL TO LBL-R-TXN
               WHEN "R_BD"         MOVE WS-MVAL TO LBL-R-BD
