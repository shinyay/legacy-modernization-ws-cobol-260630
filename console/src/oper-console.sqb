       01  WS-POST-SCRIPT            PIC X(160) VALUE SPACES.
       01  WS-POST-DIR               PIC X(160) VALUE
           "/tmp/console-demo/post".
       01  WS-POST-BDATE             PIC X(10)  VALUE "2026-06-15".
       01  WS-PREQ-PATH              PIC X(200) VALUE SPACES.
       01  WS-PRES-PATH              PIC X(200) VALUE SPACES.
       01  WS-PREQ-FS                PIC X(2)   VALUE "00".
       01  WS-PRES-FS                PIC X(2)   VALUE "00".
       01  WS-PNUM                   PIC 9(2)   VALUE 0.
       01  WS-PIDX                   PIC 9(2)   VALUE 0.
       01  WS-POST-CAT               PIC X(2)   VALUE SPACES.
       01  WS-POST-PAYER             PIC X(13)  VALUE SPACES.
       01  WS-POST-PAYEE             PIC X(13)  VALUE SPACES.
       01  WS-POST-AMT               PIC 9(15)  VALUE 0.
       01  WS-POST-AMT-DISP          PIC -Z,ZZZ,ZZZ,ZZZ,ZZ9.
       01  WS-POST-DESC              PIC X(40)  VALUE SPACES.
       01  WS-POST-BACK              PIC X(1)   VALUE "N".
       01  WS-POST-RC                PIC S9(4)  COMP-3 VALUE 0.
       01  WS-PITEMS.
           05  WS-PITEM OCCURS 10.
               10  PI-CAT            PIC X(2).
               10  PI-PAYER          PIC X(13).
               10  PI-PAYEE          PIC X(13).
               10  PI-AMT            PIC 9(15).
               10  PI-DESC           PIC X(40).
       01  WS-PRES-LINE              PIC X(160) VALUE SPACES.
