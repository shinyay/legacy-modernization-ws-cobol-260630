       IDENTIFICATION DIVISION.
       PROGRAM-ID. AUDIT-DRIVER.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
           COPY "audit-api.cpy".
       01  WS-ENV                    PIC X(120).
       01  WS-MODE                   PIC X(1).

       PROCEDURE DIVISION.
       MAIN.
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "AUDIT_MODE"
           MOVE WS-ENV(1:1) TO WS-MODE
           EVALUATE WS-MODE
               WHEN "F" PERFORM RUN-FORENSIC
               WHEN "R" PERFORM RUN-ROLLOVER
               WHEN "S" PERFORM RUN-SUMMARY
               WHEN OTHER
                   DISPLAY "AUDIT_MODE must be F/R/S"
                   STOP RUN RETURNING 8
           END-EVALUATE
           STOP RUN.

       RUN-FORENSIC.
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "AUDIT_DATE_START"
           IF FUNCTION TRIM(WS-ENV) NOT = SPACES
               COMPUTE AQF-DATE-START = FUNCTION NUMVAL(WS-ENV)
           ELSE
               MOVE 20260601 TO AQF-DATE-START
           END-IF
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "AUDIT_DATE_END"
           IF FUNCTION TRIM(WS-ENV) NOT = SPACES
               COMPUTE AQF-DATE-END = FUNCTION NUMVAL(WS-ENV)
           ELSE
               MOVE 20260630 TO AQF-DATE-END
           END-IF
           MOVE SPACES TO AQF-SUBSYSTEM
           ACCEPT AQF-SUBSYSTEM FROM ENVIRONMENT "AUDIT_SUBSYS"
           MOVE SPACES TO AQF-ACTION
           ACCEPT AQF-ACTION FROM ENVIRONMENT "AUDIT_ACTION"
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "AUDIT_SEVERITY"
           MOVE WS-ENV(1:1) TO AQF-SEVERITY
           IF AQF-SEVERITY = LOW-VALUE OR AQF-SEVERITY = SPACES
               MOVE " " TO AQF-SEVERITY
           END-IF
           MOVE SPACES TO AQF-ACCOUNT-FILTER
           ACCEPT AQF-ACCOUNT-FILTER FROM ENVIRONMENT "AUDIT_ACCT"
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "AUDIT_MAX_ROWS"
           IF FUNCTION TRIM(WS-ENV) NOT = SPACES
               COMPUTE AQF-MAX-ROWS = FUNCTION NUMVAL(WS-ENV)
           ELSE
               MOVE 1000 TO AQF-MAX-ROWS
           END-IF
           MOVE "TEXT" TO AQF-OUTPUT-FORMAT
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "AUDIT_FORMAT"
           IF FUNCTION TRIM(WS-ENV) NOT = SPACES
               MOVE WS-ENV(1:4) TO AQF-OUTPUT-FORMAT
           END-IF
           MOVE SPACES TO AQF-OUTPUT-FILENAME
           ACCEPT AQF-OUTPUT-FILENAME FROM ENVIRONMENT "AUDIT_OUT_FILE"
           MOVE "operator" TO AQF-OPERATOR-USER
           CALL "AUDIT-QUERY-FORENSIC" USING AQF-INPUT AQF-OUTPUT
           DISPLAY "STATUS=" AQF-STATUS
                   " ROWS=" AQF-OUT-ROW-COUNT
                   " QID=" AQF-OUT-QUERY-ID
           EVALUATE TRUE
               WHEN AQF-OK            STOP RUN RETURNING 0
               WHEN AQF-INVALID-INPUT STOP RUN RETURNING 8
               WHEN AQF-IO-FAIL       STOP RUN RETURNING 12
               WHEN OTHER             STOP RUN RETURNING 16
           END-EVALUATE.

       RUN-ROLLOVER.
           MOVE "operator" TO APR-OPERATOR-USER
           MOVE 30 TO APR-RETENTION-DAYS
           MOVE "N" TO APR-DRY-RUN
           MOVE "N" TO APR-ENABLE-DETACH
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "AUDIT_DRY_RUN"
           IF WS-ENV(1:1) = "Y"
               MOVE "Y" TO APR-DRY-RUN
           END-IF
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "AUDIT_ENABLE_DETACH"
           IF WS-ENV(1:1) = "Y"
               MOVE "Y" TO APR-ENABLE-DETACH
           END-IF
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "AUDIT_RETENTION_DAYS"
           IF FUNCTION TRIM(WS-ENV) NOT = SPACES
               COMPUTE APR-RETENTION-DAYS = FUNCTION NUMVAL(WS-ENV)
           END-IF
           CALL "AUDIT-PARTITION-ROLLOVER" USING APR-INPUT APR-OUTPUT
           DISPLAY "STATUS=" APR-STATUS
                   " CREATED=" APR-OUT-CREATED-COUNT
                   " DETACHED=" APR-OUT-DETACHED-COUNT
                   " NEXT=" APR-OUT-NEXT-PARTITION
           EVALUATE TRUE
               WHEN APR-OK            STOP RUN RETURNING 0
               WHEN APR-INVALID-INPUT STOP RUN RETURNING 8
               WHEN OTHER             STOP RUN RETURNING 16
           END-EVALUATE.

       RUN-SUMMARY.
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "AUDIT_DATE_START"
           IF FUNCTION TRIM(WS-ENV) NOT = SPACES
               COMPUTE ASR-DATE-START = FUNCTION NUMVAL(WS-ENV)
           ELSE
               MOVE 20260601 TO ASR-DATE-START
           END-IF
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "AUDIT_DATE_END"
           IF FUNCTION TRIM(WS-ENV) NOT = SPACES
               COMPUTE ASR-DATE-END = FUNCTION NUMVAL(WS-ENV)
           ELSE
               MOVE 20260630 TO ASR-DATE-END
           END-IF
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "AUDIT_SUMMARY_MODE"
           MOVE WS-ENV(1:1) TO ASR-MODE
           IF ASR-MODE = LOW-VALUE OR ASR-MODE = SPACES
               MOVE "D" TO ASR-MODE
           END-IF
           MOVE SPACES TO ASR-OUTPUT-FILENAME
           ACCEPT ASR-OUTPUT-FILENAME FROM ENVIRONMENT "AUDIT_OUT_FILE"
           CALL "AUDIT-SUMMARY-REPORT" USING ASR-INPUT ASR-OUTPUT
           DISPLAY "STATUS=" ASR-STATUS
                   " GROUPS=" ASR-OUT-GROUP-COUNT
                   " TOTAL=" ASR-OUT-TOTAL-ROWS
           EVALUATE TRUE
               WHEN ASR-OK            STOP RUN RETURNING 0
               WHEN ASR-INVALID-INPUT STOP RUN RETURNING 8
               WHEN ASR-IO-FAIL       STOP RUN RETURNING 12
               WHEN OTHER             STOP RUN RETURNING 16
           END-EVALUATE.
