       IDENTIFICATION DIVISION.
       PROGRAM-ID. INTI-DRIVER.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
           COPY "inti-api.cpy".
       01  WS-ENV                    PIC X(120).
       01  WS-ENV-INT                PIC 9(8).

       PROCEDURE DIVISION.
       MAIN.
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "INTI_BATCH_ID"
           MOVE WS-ENV(1:14) TO INTI-BATCH-ID
           IF INTI-BATCH-ID = SPACES
               MOVE "EBC20260613-01" TO INTI-BATCH-ID
           END-IF
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "INTI_BUSINESS_DATE"
           IF FUNCTION TRIM(WS-ENV) NOT = SPACES
               COMPUTE INTI-BUSINESS-DATE = FUNCTION NUMVAL(WS-ENV)
           ELSE
               MOVE 20260613 TO INTI-BUSINESS-DATE
           END-IF
           MOVE SPACES TO INTI-INPUT-FILENAME
           ACCEPT INTI-INPUT-FILENAME FROM ENVIRONMENT
               "INTI_INPUT_FILE"
           MOVE SPACES TO INTI-OUTPUT-FILENAME
           ACCEPT INTI-OUTPUT-FILENAME FROM ENVIRONMENT
               "INTI_OUTPUT_FILE"
           MOVE SPACES TO INTI-REJECT-FILENAME
           ACCEPT INTI-REJECT-FILENAME FROM ENVIRONMENT
               "INTI_REJECT_FILE"
           MOVE SPACES TO INTI-SENTINEL-FILENAME
           ACCEPT INTI-SENTINEL-FILENAME FROM ENVIRONMENT
               "INTI_SENTINEL_FILE"
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "INTI_REQUIRE_SENTINEL"
           IF WS-ENV(1:1) = "Y"
               MOVE "Y" TO INTI-REQUIRE-SENTINEL
           ELSE
               MOVE "N" TO INTI-REQUIRE-SENTINEL
           END-IF
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "INTI_REJECT_THRESHOLD_PCT"
           IF FUNCTION TRIM(WS-ENV) NOT = SPACES
               COMPUTE INTI-REJECT-THRESHOLD-PCT =
                   FUNCTION NUMVAL(WS-ENV)
           ELSE
               MOVE 5 TO INTI-REJECT-THRESHOLD-PCT
           END-IF

           CALL "INTI-DECODE-BATCH" USING INTI-INPUT INTI-OUTPUT

           DISPLAY "STATUS=" INTI-STATUS
                   " READ=" INTI-OUT-RECORDS-READ
                   " DECODED=" INTI-OUT-DETAILS-DECODED
                   " REJECTED=" INTI-OUT-DETAILS-REJECTED
                   " PCT=" INTI-OUT-REJECT-PCT
                   " CSUM=" INTI-OUT-CHECKSUM-MATCH
           IF INTI-OK
               STOP RUN RETURNING 0
           END-IF
           EVALUATE TRUE
               WHEN INTI-NO-INPUT-READY  STOP RUN RETURNING 1
               WHEN INTI-PARTIAL         STOP RUN RETURNING 4
               WHEN INTI-INVALID-INPUT   STOP RUN RETURNING 8
               WHEN INTI-IO-FAIL         STOP RUN RETURNING 12
               WHEN OTHER                STOP RUN RETURNING 16
           END-EVALUATE.
