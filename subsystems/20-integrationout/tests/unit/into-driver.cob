       IDENTIFICATION DIVISION.
       PROGRAM-ID. INTO-DRIVER.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
           COPY "into-api.cpy".
       01  WS-ENV                    PIC X(120).

       PROCEDURE DIVISION.
       MAIN.
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "INTO_OP"
           IF WS-ENV(1:1) = "D"
               PERFORM RUN-DRAIN
               STOP RUN
           END-IF
           MOVE SPACES TO INTO-EVENT-TYPE
           ACCEPT INTO-EVENT-TYPE FROM ENVIRONMENT "INTO_EVENT_TYPE"
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "INTO_BUSINESS_DATE"
           IF FUNCTION TRIM(WS-ENV) NOT = SPACES
               COMPUTE INTO-BUSINESS-DATE = FUNCTION NUMVAL(WS-ENV)
           ELSE
               MOVE 20260613 TO INTO-BUSINESS-DATE
           END-IF
           MOVE SPACES TO INTO-BATCH-ID
           ACCEPT INTO-BATCH-ID FROM ENVIRONMENT "INTO_BATCH_ID"
           MOVE SPACES TO INTO-TXN-ID
           ACCEPT INTO-TXN-ID FROM ENVIRONMENT "INTO_TXN_ID"
           MOVE SPACES TO INTO-ACCOUNT
           ACCEPT INTO-ACCOUNT FROM ENVIRONMENT "INTO_ACCOUNT"
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "INTO_AMOUNT_JPY"
           IF FUNCTION TRIM(WS-ENV) NOT = SPACES
               COMPUTE INTO-AMOUNT-JPY = FUNCTION NUMVAL(WS-ENV)
           END-IF
           MOVE SPACES TO INTO-CATEGORY
           ACCEPT INTO-CATEGORY FROM ENVIRONMENT "INTO_CATEGORY"
           MOVE SPACES TO INTO-REASON
           ACCEPT INTO-REASON FROM ENVIRONMENT "INTO_REASON"
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "INTO_COUNT"
           IF FUNCTION TRIM(WS-ENV) NOT = SPACES
               COMPUTE INTO-COUNT = FUNCTION NUMVAL(WS-ENV)
           END-IF
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "INTO_MODE"
           EVALUATE WS-ENV(1:1)
               WHEN "M" MOVE "M" TO INTO-MODE
               WHEN "R" MOVE "R" TO INTO-MODE
               WHEN OTHER MOVE " " TO INTO-MODE
           END-EVALUATE

           CALL "INTO-PUBLISH-EVENT" USING INTO-INPUT INTO-OUTPUT

           DISPLAY "STATUS=" INTO-STATUS
                   " EVENT-ID=" INTO-EVENT-ID
                   " RETRIES=" INTO-RETRY-COUNT
           EVALUATE TRUE
               WHEN INTO-OK              STOP RUN RETURNING 0
               WHEN INTO-RETRY-EXHAUSTED STOP RUN RETURNING 4
               WHEN INTO-INVALID-INPUT   STOP RUN RETURNING 8
               WHEN INTO-BROKER-FAIL     STOP RUN RETURNING 12
               WHEN OTHER                STOP RUN RETURNING 16
           END-EVALUATE.

       RUN-DRAIN.
           MOVE SPACES TO INTD-SOURCE-FILENAME
           ACCEPT INTD-SOURCE-FILENAME FROM ENVIRONMENT
               "INTD_SOURCE_FILE"
           MOVE 100 TO INTD-MAX-RECORDS
           MOVE "M" TO INTD-MODE
           MOVE SPACES TO WS-ENV
           ACCEPT WS-ENV FROM ENVIRONMENT "INTD_MODE"
           IF WS-ENV(1:1) = "R"
               MOVE "R" TO INTD-MODE
           END-IF
           CALL "INTO-DRAIN-QUEUE" USING INTD-INPUT INTD-OUTPUT
           DISPLAY "DRAIN-STATUS=" INTD-STATUS
                   " DRAINED=" INTD-OUT-DRAINED-COUNT
                   " FAILED=" INTD-OUT-FAILED-COUNT
           EVALUATE INTD-STATUS
               WHEN "00" STOP RUN RETURNING 0
               WHEN "04" STOP RUN RETURNING 4
               WHEN "08" STOP RUN RETURNING 8
               WHEN "12" STOP RUN RETURNING 12
               WHEN OTHER STOP RUN RETURNING 16
           END-EVALUATE.
