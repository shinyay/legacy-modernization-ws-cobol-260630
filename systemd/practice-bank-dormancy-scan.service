[Unit]
Description=PRACTICE BANK Weekly Dormancy Scan Run (= 9-ALC ALC-DORMANCY-SCAN)
After=network.target postgresql.service

[Service]
Type=oneshot
User=batch
Group=batch
WorkingDirectory=/opt/practice-bank
EnvironmentFile=/opt/practice-bank/etc/practice-bank.env
ExecStart=/usr/bin/make -C /opt/practice-bank/subsystems/22-operations scan-dormancy
StandardOutput=journal
StandardError=journal
TimeoutStartSec=1h

[Install]
WantedBy=multi-user.target
